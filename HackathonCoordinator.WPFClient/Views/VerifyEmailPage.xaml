<Page x:Class="HackathonCoordinator.WPFClient.Views.VerifyEmailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:HackathonCoordinator.WPFClient.Views"
      Title="VerifyEmailPage">

    <Grid>
        <Border Background="#F5F5F5"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                CornerRadius="10"
                Width="350" Height="250"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <StackPanel Margin="30" VerticalAlignment="Center">
                <TextBlock Text="Подтверждение Email" 
                           FontSize="22" FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,20"/>

                <TextBox Text="{Binding Code, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,20" />

                <Button Content="Подтвердить" 
                        Command="{Binding VerifyCommand}" 
                        Height="40" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
