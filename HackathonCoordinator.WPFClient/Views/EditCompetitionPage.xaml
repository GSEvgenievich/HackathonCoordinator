<Page x:Class="HackathonCoordinator.WPFClient.Views.EditCompetitionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:HackathonCoordinator.WPFClient.ViewModels"
      Title="Редактирование соревнования"
      Unloaded="Page_Unloaded">

    <Page.DataContext>
        <vm:EditCompetitionViewModel/>
    </Page.DataContext>

    <Grid Margin="30">
        <ScrollViewer x:Name="MainScrollViewer" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Заголовок страницы -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="← Назад к соревнованиям" 
                                Command="{Binding CancelCommand}"
                                Style="{StaticResource NavigationButton}"
                                Margin="0,0,20,0"/>

                        <StackPanel>
                            <TextBlock Text="{Binding PageTitle}" 
                                   Style="{StaticResource PageHeaderStyle}"/>
                            <TextBlock Text="{Binding PageSubtitle}"
                                   Style="{StaticResource PageSubtitleStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Форма редактирования -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <!-- Название -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="🏷️ Название соревнования"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Margin="0,0,0,8"/>
                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Tag="Введите название соревнования:"/>
                            <TextBlock Text="* Обязательное поле"
                                   Style="{StaticResource CaptionSecondaryStyle}"
                                   Margin="0,5,0,0"/>
                        </StackPanel>

                        <!-- Описание -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="📝 Описание"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Margin="0,0,0,8"/>
                            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Height="70"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Tag="Опишите соревнование:"/>
                        </StackPanel>

                        <!-- Даты проведения -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="📅 Даты проведения"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Margin="0,0,0,8"/>

                            <Border Style="{StaticResource StatsContainerStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Дата начала -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Дата начала *"
                                               Style="{StaticResource StatsHeaderStyle}"
                                               Margin="0,0,0,8"/>
                                        <DatePicker SelectedDate="{Binding StartDate}"
                                                Style="{StaticResource ModernDatePicker}"
                                                Margin="0,0,0,15"/>
                                        <TextBlock Text="Время начала *"
                                               Style="{StaticResource StatsHeaderStyle}"
                                               Margin="0,0,0,8"/>
                                        <TextBox Text="{Binding StartTime, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ModernTextBox}"
                                             Tag="HH:mm (например: 09:00)"/>
                                    </StackPanel>

                                    <!-- Разделитель -->
                                    <Rectangle Grid.Column="1" Style="{StaticResource VerticalDividerStyle}"/>

                                    <!-- Дата окончания -->
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Дата окончания *"
                                               Style="{StaticResource StatsHeaderStyle}"
                                               Margin="0,0,0,8"/>
                                        <DatePicker SelectedDate="{Binding EndDate}"
                                                Style="{StaticResource ModernDatePicker}"
                                                Margin="0,0,0,15"/>
                                        <TextBlock Text="Время окончания *"
                                               Style="{StaticResource StatsHeaderStyle}"
                                               Margin="0,0,0,8"/>
                                        <TextBox Text="{Binding EndTime, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ModernTextBox}"
                                             Tag="HH:mm (например: 18:00)"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Кнопки действий -->
                        <Border Style="{StaticResource StatsContainerStyle}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Отмена"
                                    Command="{Binding CancelCommand}"
                                    Style="{StaticResource ModalSecondaryButton}"
                                    Margin="0,0,12,0"/>

                                <Button Content="{Binding SaveButtonText}"
                                    Command="{Binding SaveCommand}"
                                    Style="{StaticResource ModalPrimaryButton}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Сообщения об ошибках -->
                <Border Style="{StaticResource StatsContainerStyle}"
                        Background="{DynamicResource DangerBrush}"
                        Visibility="{Binding HasErrorMessage, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠️"
                               Style="{StaticResource BodyLargeStyle}"
                               Foreground="White"
                               Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                               Style="{StaticResource BodyTextStyle}"
                               Foreground="White"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>