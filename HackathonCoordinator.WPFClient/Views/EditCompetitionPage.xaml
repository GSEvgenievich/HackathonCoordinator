<Page x:Class="HackathonCoordinator.WPFClient.Views.EditCompetitionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:HackathonCoordinator.WPFClient.ViewModels"
      Title="Редактирование соревнования">

    <Page.DataContext>
        <vm:EditCompetitionViewModel/>
    </Page.DataContext>

    <Grid Margin="30">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Width="600" HorizontalAlignment="Left">

                <!-- Заголовок -->
                <TextBlock Text="{Binding PageTitle}" 
                           FontSize="26" 
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextColor}"
                           Margin="0,0,0,20"/>

                <!-- Форма редактирования -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <!-- Название -->
                        <TextBlock Text="Название соревнования *"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextColor}"
                                   Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Margin="0,0,0,15"/>

                        <!-- Описание -->
                        <TextBlock Text="Описание"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextColor}"
                                   Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Height="80"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,15"/>

                        <!-- Даты проведения -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Дата начала -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Дата начала *"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextColor}"
                                           Margin="0,0,0,5"/>
                                <DatePicker SelectedDate="{Binding StartDate}"
                                            Style="{StaticResource ModernDatePicker}"/>
                                <TextBlock Text="Время начала *"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextColor}"
                                           Margin="0,10,0,5"/>
                                <TextBox Text="{Binding StartTime, UpdateSourceTrigger=PropertyChanged}"
                                         Tag="HH:mm"
                                         Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>

                            <!-- Пустой разделитель -->
                            <Rectangle Grid.Column="1" Fill="Transparent"/>

                            <!-- Дата окончания -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Дата окончания *"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextColor}"
                                           Margin="0,0,0,5"/>
                                <DatePicker SelectedDate="{Binding EndDate}"
                                            Style="{StaticResource ModernDatePicker}"/>
                                <TextBlock Text="Время окончания *"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextColor}"
                                           Margin="0,10,0,5"/>
                                <TextBox Text="{Binding EndTime, UpdateSourceTrigger=PropertyChanged}"
                                         Tag="HH:mm"
                                         Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Статус (только для редактирования) -->
                        <CheckBox IsChecked="{Binding IsActive}"
                                  Content="Соревнование активно"
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource TextColor}"
                                  Margin="0,0,0,20"
                                  Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <!-- Кнопки действий -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Отмена"
                                    Command="{Binding CancelCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="0,0,10,0"/>

                            <Button Content="{Binding SaveButtonText}"
                                    Command="{Binding SaveCommand}"
                                    Style="{StaticResource PrimaryButton}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Сообщения об ошибках -->
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource DangerBrush}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Margin="0,10,0,0"
                           Visibility="{Binding HasErrorMessage, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>