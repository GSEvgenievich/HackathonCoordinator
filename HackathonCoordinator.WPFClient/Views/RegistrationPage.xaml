<Page x:Class="HackathonCoordinator.WPFClient.Views.RegistrationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:vm="clr-namespace:HackathonCoordinator.WPFClient.ViewModels" 
      xmlns:local="clr-namespace:HackathonCoordinator.WPFClient.Views"
      mc:Ignorable="d" 
      Title="RegistrationPage"
      Background="White">
    
    <Page.DataContext>
        <vm:RegistrationViewModel/>
    </Page.DataContext>
    
    <Grid>
        <Border Background="#F5F5F5" 
                BorderBrush="#DDDDDD" 
                BorderThickness="1" 
                CornerRadius="10"
                Width="400" 
                Height="500"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="30" VerticalAlignment="Center">
                    <TextBlock Text="Регистрация" 
                              FontSize="24" 
                              FontWeight="Bold" 
                              HorizontalAlignment="Center" 
                              Margin="0,0,0,25"
                              Foreground="#333333"/>

                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Имя пользователя"
                             Style="{StaticResource ModernTextBox}"
                             Margin="0,0,0,15"/>

                    <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Логин"
                             Style="{StaticResource ModernTextBox}"
                             Margin="0,0,0,15"/>

                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Email"
                             Style="{StaticResource ModernTextBox}"
                             Margin="0,0,0,15"/>

                    <PasswordBox x:Name="PasswordBox"
                                 Tag="Пароль"
                                 Style="{StaticResource ModernPasswordBox}"
                                 Margin="0,0,0,15"/>

                    <PasswordBox x:Name="ConfirmPasswordBox"
                                 Tag="Подтвердите пароль"
                                 Style="{StaticResource ModernPasswordBox}"
                                 Margin="0,0,0,25"/>

                    <Button Content="Зарегистрироваться" 
                            Command="{Binding RegisterCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Height="40"
                            Margin="0,0,0,20"/>

                    <TextBlock Text="Уже есть аккаунт?" 
                              HorizontalAlignment="Center" 
                              Foreground="#666666"
                              Margin="0,0,0,10"/>

                    <Button Content="Войти" 
                            Command="{Binding NavigateToAuthorizationCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Height="35"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
