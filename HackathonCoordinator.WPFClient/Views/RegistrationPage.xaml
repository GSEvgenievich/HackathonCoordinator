<Page x:Class="HackathonCoordinator.WPFClient.Views.RegistrationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:vm="clr-namespace:HackathonCoordinator.WPFClient.ViewModels" 
      mc:Ignorable="d" 
      Title="Регистрация">

    <Page.DataContext>
        <vm:RegistrationViewModel/>
    </Page.DataContext>

    <Grid>
        <Border Style="{StaticResource CardStyle}"
                Background="{DynamicResource AccentBackgroundBrush}"
                Width="400"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Padding="40">

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="Регистрация" 
                               Style="{StaticResource PageTitleStyle}"/>

                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Имя пользователя"
                             Style="{StaticResource ModernTextBox}"
                             Margin="0,0,0,15"/>

                    <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Логин"
                             Style="{StaticResource ModernTextBox}"
                             Margin="0,0,0,15"/>

                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Email"
                             Style="{StaticResource ModernTextBox}"
                             Margin="0,0,0,15"/>

                    <PasswordBox x:Name="PasswordBox"
                                 Tag="Пароль"
                                 Style="{StaticResource ModernPasswordBox}"
                                 Margin="0,0,0,15"/>

                    <PasswordBox x:Name="ConfirmPasswordBox"
                                 Tag="Подтвердите пароль"
                                 Style="{StaticResource ModernPasswordBox}"
                                 Margin="0,0,0,25"/>
                    <Border Style="{StaticResource CardStyle}"
                            Background="{DynamicResource ControlBackground}">
                        <StackPanel>
                            <Button Content="Зарегистрироваться" 
                                Command="{Binding RegisterCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,0,0,20"/>
                            <StackPanel Orientation="Horizontal" 
                                        HorizontalAlignment="Center">
                                <TextBlock Text="Уже есть аккаунт?" 
                                           Style="{StaticResource BodyTextStyle}"
                                           VerticalAlignment="Center"/>
                                <Button Content="Войти" 
                                        Command="{Binding NavigateToAuthorizationCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                         Margin="10,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>