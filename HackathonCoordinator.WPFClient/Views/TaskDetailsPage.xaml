<Page x:Class="HackathonCoordinator.WPFClient.Views.TaskDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:HackathonCoordinator.WPFClient.ViewModels"
      xmlns:converters="clr-namespace:HackathonCoordinator.WPFClient.Converters"
      Title="Задача">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Page.DataContext>
        <vm:TaskDetailsViewModel/>
    </Page.DataContext>

    <Grid Margin="30">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Заголовок и кнопка возврата -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Button Content="← Назад к проекту" 
                            Command="{Binding BackCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,20,0"/>

                    <TextBlock Text="{Binding Task.Title}" 
                               FontSize="26" 
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextColor}"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Информация о задаче -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                    <StackPanel>
                        <!-- Заголовок и действия -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="Информация о задаче"
                                       FontWeight="SemiBold"
                                       FontSize="18"
                                       Foreground="{DynamicResource TextColor}"/>

                            <!-- Кнопки действий -->
                            <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                                <!-- Редактировать (только для капитана) -->
                                <Button Content="✏️ Редактировать"
                                        Command="{Binding EditTaskCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="10,6"
                                        Margin="0,0,10,0"
                                        Visibility="{Binding CanEditTask, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                <!-- Назначить задачу (капитан, нет исполнителя) -->
                                <Button Content="🎯 Назначить"
                                        Command="{Binding AssignTaskCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Padding="10,6"
                                        Margin="0,0,10,0"
                                        Visibility="{Binding CanAssignTask, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                <!-- Чат задачи -->
                                <Button Content="💬 Чат задачи"
                                        Command="{Binding OpenTaskChatCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="10,6"
                                        Margin="0,0,10,0"
                                        Visibility="{Binding HasChat, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Описание задачи -->
                        <TextBlock Text="{Binding Task.Description}"
                                   Style="{StaticResource BodyTextStyle}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,15"/>

                        <!-- Детали задачи -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Статус -->
                            <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,30,15">
                                <TextBlock Text="Статус:"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextColor}"
                                           Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding Task.StatusName}"
                                           Style="{StaticResource BodyTextStyle}"
                                           FontWeight="SemiBold"/>
                            </StackPanel>

                            <!-- Тип -->
                            <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,30,15">
                                <TextBlock Text="Тип:"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextColor}"
                                           Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding Task.TypeName}"
                                           Style="{StaticResource BodyTextStyle}"/>
                            </StackPanel>

                            <!-- Исполнитель -->
                            <StackPanel Grid.Column="2" Grid.Row="0" Margin="0,0,30,15">
                                <TextBlock Text="Исполнитель:"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextColor}"
                                           Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding Task.AssignedToUsername, FallbackValue='Не назначен'}"
                                           Style="{StaticResource BodyTextStyle}"/>
                            </StackPanel>

                            <!-- Дедлайн -->
                            <StackPanel Grid.Column="3" Grid.Row="0" Margin="0,0,0,15">
                                <TextBlock Text="Дедлайн:"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextColor}"
                                           Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding Task.Deadline, StringFormat='{}{0:dd.MM.yyyy}'}"
                                           Style="{StaticResource BodyTextStyle}"/>
                            </StackPanel>

                            <!-- GitHub ветка -->
                            <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,30,0">
                                <TextBlock Text="GitHub ветка:"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextColor}"
                                           Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding Task.GithubBranchName, FallbackValue='Не указана'}"
                                           Style="{StaticResource BodyTextStyle}"/>
                            </StackPanel>

                            <!-- Дата создания -->
                            <StackPanel Grid.Column="1" Grid.Row="1" Margin="0,0,30,0">
                                <TextBlock Text="Создана:"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextColor}"
                                           Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding Task.CreatedAt, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"
                                           Style="{StaticResource BodyTextStyle}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Действия для исполнителя -->
                <Border Style="{StaticResource CardStyle}" 
                        Visibility="{Binding IsMyTask, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="Мои действия"
                                   FontWeight="SemiBold"
                                   FontSize="18"
                                   Foreground="{DynamicResource TextColor}"
                                   Margin="0,0,0,15"/>

                        <StackPanel Orientation="Horizontal">
                            <!-- Запрос завершения -->
                            <Button Content="✅ Завершить задачу"
                                    Command="{Binding CompleteTaskCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,0,10,0"
                                    Visibility="{Binding CanCompleteTask, Converter={StaticResource BoolToVisibilityConverter}}"/>

                            <!-- Запрос отмены -->
                            <Button Content="❌ Отменить задачу"
                                    Command="{Binding CancelTaskCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Background="{DynamicResource DangerBrush}"
                                    Visibility="{Binding CanCancelTask, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>

                        <TextBlock Text="Для завершения или отмены задачи требуется подтверждение капитана"
                                   Style="{StaticResource BodyTextStyle}"
                                   FontSize="12"
                                   Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>