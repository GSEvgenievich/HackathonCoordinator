<Page x:Class="HackathonCoordinator.WPFClient.Views.TaskDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:HackathonCoordinator.WPFClient.ViewModels"
      Title="Задача"
      Unloaded="Page_Unloaded">

    <Page.DataContext>
        <vm:TaskDetailsViewModel/>
    </Page.DataContext>

    <Grid Margin="30">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Заголовок страницы -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="← Назад" 
                                Command="{Binding BackCommand}"
                                Style="{StaticResource NavigationButton}"
                                Margin="0,0,20,0"/>

                        <StackPanel>
                            <TextBlock Text="{Binding Task.Title}" 
                                   Style="{StaticResource PageHeaderStyle}"
                                   TextWrapping="Wrap"/>
                            <TextBlock Text="Просмотр и управление задачей"
                                   Style="{StaticResource PageSubtitleStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Основная информация о задаче -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                    <StackPanel>

                        <!-- Заголовок и действия -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="📋 Информация о задаче"
                                   Style="{StaticResource SectionHeaderStyle}"/>

                            <!-- Кнопки действий -->
                            <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                                <!-- Редактировать -->
                                <Button Content="✏️ Редактировать"
                                        Command="{Binding EditTaskCommand}"
                                        Style="{StaticResource ActionButton}"
                                        Margin="0,0,10,0"
                                        Visibility="{Binding CanEditTask, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                <!-- Назначить задачу -->
                                <Button Content="🎯 Назначить"
                                        Command="{Binding OpenAssignmentDialogCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Margin="0,0,10,0"
                                        Visibility="{Binding CanAssignTask, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                <!-- Чат задачи -->
                                <Button Content="💬 Чат задачи"
                                        Command="{Binding OpenTaskChatCommand}"
                                        Style="{StaticResource ActionButton}"
                                        Visibility="{Binding CanOpenChat, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Описание задачи -->
                        <Border Style="{StaticResource StatsContainerStyle}" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="📄 Описание"
                                       Style="{StaticResource StatsHeaderStyle}"
                                       Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding Task.Description}"
                                       Style="{StaticResource BodyTextStyle}"
                                       TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Детали задачи -->
                        <Border Style="{StaticResource StatsContainerStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Статус -->
                                <StackPanel Grid.Column="0" Grid.Row="0">
                                    <TextBlock Text="📊 Статус"
                                           Style="{StaticResource StatsHeaderStyle}"
                                           Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding Task.StatusName}"
                                           Style="{StaticResource StatsValueStyle}"/>
                                </StackPanel>

                                <!-- Разделитель -->
                                <Rectangle Grid.Column="1" Grid.Row="0" Style="{StaticResource VerticalDividerStyle}"/>

                                <!-- Тип -->
                                <StackPanel Grid.Column="2" Grid.Row="0">
                                    <TextBlock Text="🎯 Тип"
                                           Style="{StaticResource StatsHeaderStyle}"
                                           Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding Task.TypeName}"
                                           Style="{StaticResource StatsValueStyle}"/>
                                </StackPanel>

                                <!-- Разделитель -->
                                <Rectangle Grid.Column="3" Grid.Row="0" Style="{StaticResource VerticalDividerStyle}"/>

                                <!-- Исполнитель -->
                                <StackPanel Grid.Column="4" Grid.Row="0">
                                    <TextBlock Text="👤 Исполнитель"
                                           Style="{StaticResource StatsHeaderStyle}"
                                           Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding DisplayAssignedTo, FallbackValue='Не назначен'}"
                                           Style="{StaticResource StatsValueStyle}"/>
                                </StackPanel>

                                <!-- Дедлайн -->
                                <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,15,0,0">
                                    <TextBlock Text="⏰ Дедлайн"
                                               Style="{StaticResource StatsHeaderStyle}"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding Task.Deadline, Converter={StaticResource DeadlineDisplayConverter}}"
                                               Style="{StaticResource StatsValueStyle}"/>
                                </StackPanel>

                                <!-- Разделитель -->
                                <Rectangle Grid.Column="1" Grid.Row="1" Style="{StaticResource VerticalDividerStyle}"/>

                                <!-- GitHub ветка -->
                                <StackPanel Grid.Column="2" Grid.Row="1" Margin="0,15,0,0">
                                    <TextBlock Text="🔗 GitHub ветка"
                                           Style="{StaticResource StatsHeaderStyle}"
                                           Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding DisplayGitHubBranch, FallbackValue='Не указана'}"
                                           Style="{StaticResource StatsValueStyle}"/>
                                </StackPanel>

                                <!-- Разделитель -->
                                <Rectangle Grid.Column="3" Grid.Row="1" Style="{StaticResource VerticalDividerStyle}"/>

                                <!-- Дата создания -->
                                <StackPanel Grid.Column="4" Grid.Row="1" Margin="0,15,0,0">
                                    <TextBlock Text="📅 Создана"
                                           Style="{StaticResource StatsHeaderStyle}"
                                           Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding Task.CreatedAt, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"
                                           Style="{StaticResource StatsValueStyle}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Действия для исполнителя -->
                <Border Style="{StaticResource CardStyle}" 
                        Visibility="{Binding IsMyTask, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="🚀 Мои действия"
                                   Style="{StaticResource SectionHeaderStyle}"
                                   Margin="0,0,0,15"/>

                        <StackPanel Orientation="Horizontal">
                            <!-- Запрос завершения -->
                            <Button Content="✅ Запросить завершение"
                                    Command="{Binding CompleteTaskCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,0,10,0"
                                    Visibility="{Binding CanCompleteTask, Converter={StaticResource BoolToVisibilityConverter}}"/>

                            <!-- Запрос отмены -->
                            <Button Content="❌ Запросить отмену"
                                    Command="{Binding CancelTaskCommand}"
                                    Style="{StaticResource ActionButton}"
                                    BorderBrush="{DynamicResource DangerBrush}"
                                    Foreground="{DynamicResource DangerBrush}"
                                    Visibility="{Binding CanCancelTask, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>

                        <TextBlock Text="Для завершения или отмены задачи требуется подтверждение капитана"
                                   Style="{StaticResource CaptionSecondaryStyle}"
                                   Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Действия для капитана -->
                <Border Style="{StaticResource CardStyle}" 
                        Visibility="{Binding CanEditTask, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="👑 Действия капитана"
                                   Style="{StaticResource SectionHeaderStyle}"
                                   Margin="0,0,0,15"/>

                        <StackPanel Orientation="Horizontal">
                            <!-- Подтвердить завершение -->
                            <Button Content="✅ Подтвердить завершение"
                                    Command="{Binding ConfirmCompletionCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Background="{DynamicResource SuccessBrush}"
                                    Margin="0,0,10,0"
                                    Visibility="{Binding CanConfirmCompletion, Converter={StaticResource BoolToVisibilityConverter}}"/>

                            <!-- Отклонить завершение -->
                            <Button Content="❌ Отклонить завершение"
                                    Command="{Binding RejectCompletionCommand}"
                                    Style="{StaticResource ActionButton}"
                                    BorderBrush="{DynamicResource WarningBrush}"
                                    Foreground="{DynamicResource WarningBrush}"
                                    Margin="0,0,10,0"
                                    Visibility="{Binding CanRejectCompletion, Converter={StaticResource BoolToVisibilityConverter}}"/>

                            <!-- Отменить задачу -->
                            <Button Content="🗑️ Отменить задачу"
                                    Command="{Binding CancelTaskAsCaptainCommand}"
                                    Style="{StaticResource ActionButton}"
                                    BorderBrush="{DynamicResource DangerBrush}"
                                    Foreground="{DynamicResource DangerBrush}"
                                    Visibility="{Binding CanCancelTaskAsCaptain, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>

                        <TextBlock Text="Управление статусами задач команды"
                                   Style="{StaticResource CaptionSecondaryStyle}"
                                   Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Модальное окно назначения задачи -->
        <Border Style="{StaticResource ModalOverlayStyle}"
                Visibility="{Binding ShowAssignmentDialog, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Style="{StaticResource ModalDialogStyle}" Width="450">
                <StackPanel>
                    <!-- Заголовок с иконкой -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="🎯"
                                   FontSize="20"
                                   Margin="0,0,10,0"/>
                        <TextBlock Text="Назначение задачи"
                               Style="{StaticResource ModalTitleStyle}"/>
                    </StackPanel>

                    <!-- Информация о задаче -->
                    <Border Style="{StaticResource StatsContainerStyle}" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="{Binding Task.Title}"
                                   Style="{StaticResource BodyTextStyle}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                            <TextBlock Text="Выберите исполнителя для этой задачи"
                                   Style="{StaticResource CaptionSecondaryStyle}"
                                   Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Выбор исполнителя -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Исполнитель *"
                               Style="{StaticResource StatsHeaderStyle}"
                               Margin="0,0,0,8"/>
                        <ComboBox ItemsSource="{Binding AvailableAssignees}"
                              SelectedItem="{Binding SelectedAssignee}"
                              DisplayMemberPath="Username"
                              Style="{StaticResource ModernComboBox}"/>
                    </StackPanel>

                    <!-- Кнопки действий -->
                    <DockPanel>
                        <Button Content="Отмена"
                                Command="{Binding CancelAssignmentCommand}"
                                Style="{StaticResource ModalSecondaryButton}"/>

                        <Button Content="Назначить"
                                Command="{Binding AssignTaskCommand}"
                                Style="{StaticResource ModalPrimaryButton}"
                                Background="{DynamicResource InfoBrush}"
                                Margin="10,0,10,0"/>
                    </DockPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Page>