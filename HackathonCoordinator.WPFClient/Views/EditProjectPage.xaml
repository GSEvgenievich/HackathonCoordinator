<Page x:Class="HackathonCoordinator.WPFClient.Views.EditProjectPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:HackathonCoordinator.WPFClient.ViewModels"
      xmlns:converters="clr-namespace:HackathonCoordinator.WPFClient.Converters"
      Title="Редактирование проекта">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Page.DataContext>
        <vm:EditProjectViewModel/>
    </Page.DataContext>

    <Grid Margin="30">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Width="600" HorizontalAlignment="Left">

                <!-- Заголовок -->
                <TextBlock Text="{Binding PageTitle}" 
                           FontSize="26" 
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextColor}"
                           Margin="0,0,0,20"/>

                <!-- Форма редактирования -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <!-- Название -->
                        <TextBlock Text="Название проекта *"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextColor}"
                                   Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Margin="0,0,0,15"/>

                        <!-- Описание -->
                        <TextBlock Text="Описание проекта"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextColor}"
                                   Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Height="120"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,15"/>

                        <!-- GitHub репозиторий -->
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="GitHub репозиторий"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextColor}"
                                       Margin="0,0,0,5"/>
                            <TextBox Text="{Binding GithubRepoName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"
                                     IsEnabled="{Binding CanEditGitHubRepo}"/>
                            <TextBlock Text="Название репозитория в GitHub (опционально)"
                                       Style="{StaticResource BodyTextStyle}"
                                       FontSize="12"
                                       Margin="0,5,0,0"/>
                        </StackPanel>

                        <!-- Создание GitHub репозитория (только при создании) -->
                        <CheckBox IsChecked="{Binding CreateGitHubRepo}"
                                  Content="Создать GitHub репозиторий"
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource TextColor}"
                                  Margin="0,0,0,10"
                                  Visibility="{Binding IsCreateMode, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <!-- Информация о GitHub -->
                        <Border Background="{DynamicResource InfoBackground}"
                                BorderBrush="{DynamicResource InfoBorder}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10"
                                Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="ℹ️ Информация о GitHub интеграции"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource InfoText}"
                                           Margin="0,0,0,5"/>
                                <TextBlock Text="При создании проекта будет автоматически создан GitHub репозиторий с выбранным названием. Все задачи проекта будут связаны с этим репозиторием."
                                           Style="{StaticResource BodyTextStyle}"
                                           FontSize="12"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Кнопки действий -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Отмена"
                                    Command="{Binding CancelCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="0,0,10,0"/>

                            <Button Content="{Binding SaveButtonText}"
                                    Command="{Binding SaveCommand}"
                                    Style="{StaticResource PrimaryButton}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Сообщения об ошибках -->
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource DangerBrush}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Margin="0,10,0,0"
                           Visibility="{Binding HasErrorMessage, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>