<Page x:Class="HackathonCoordinator.WPFClient.Views.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:HackathonCoordinator.WPFClient.ViewModels"
      Title="Профиль"
      Unloaded="Page_Unloaded">

    <Page.Resources>
        <Style x:Key="RoundIconButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>
    </Page.Resources>

    <Page.DataContext>
        <vm:ProfileViewModel/>
    </Page.DataContext>

    <Grid>
        <Border Style="{StaticResource CardStyle}"
                Padding="30"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10">
                <!-- Фото профиля -->
                <Grid HorizontalAlignment="Center" Margin="0,0,0,20">
                    <Border Width="100" Height="100" CornerRadius="50" 
                            BorderBrush="{DynamicResource BorderColor}" BorderThickness="2">
                        <Border.Clip>
                            <EllipseGeometry RadiusX="50" RadiusY="50" Center="50,50"/>
                        </Border.Clip>
                        <Image Source="{Binding CurrentIconPath}" Stretch="UniformToFill" />
                    </Border>

                    <!-- Иконка редактирования -->
                    <Button Content="🖉"
                            ToolTip="Изменить иконку"
                            Command="{Binding ChangeIconCommand}"
                            Style="{StaticResource RoundIconButton}"
                            VerticalAlignment="Bottom"
                            HorizontalAlignment="Right"
                            Margin="0,0,5,5"/>
                </Grid>

                <!-- Информация о пользователе -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,15">
                    <TextBlock Text="{Binding Username}" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="{DynamicResource TextColor}" 
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Email}" 
                               Style="{StaticResource BodyTextStyle}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TeamName, StringFormat='Команда: {0}'}"
                               Style="{StaticResource BodyTextStyle}"
                               HorizontalAlignment="Center"
                               Margin="0,5,0,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <TextBlock Text="GitHub: "
                                   Style="{StaticResource BodyTextStyle}"/>
                        <TextBlock Text="{Binding GitHubStatus}"
                                   Style="{StaticResource BodyTextStyle}"
                                   Foreground="{Binding GitHubStatusColor}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Редактирование имени -->
                <TextBlock Text="Изменить имя пользователя:" 
                           FontWeight="Bold" 
                           Foreground="{DynamicResource TextColor}" />
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBox}"
                         Width="250"
                         Margin="0,5,0,15"/>

                <!-- Кнопки действий -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                    <Button Content="Сохранить изменения"
                            Command="{Binding SaveProfileCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,10,0"/>
                    <Button Content="{Binding GitHubButtonText}"
                            Command="{Binding LinkGitHubCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,10,0"/>
                    <Button Content="Выйти"
                            Command="{Binding LogoutCommand}"
                            Style="{StaticResource SecondaryButton}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Панель выбора иконок -->
        <Border Background="{DynamicResource CardBackground}"
                CornerRadius="10"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1"
                Padding="5"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="{Binding IsIconPanelVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                Height="150" Width="170">

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding AvailableIcons}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Width="60" Height="60"
                                    Margin="5"
                                    BorderBrush="{Binding IsSelected, Converter={StaticResource BoolToBrushConverter}}"
                                    BorderThickness="2"
                                    Command="{Binding DataContext.SelectIconCommand, 
                                              RelativeSource={RelativeSource AncestorType=Page}}"
                                    CommandParameter="{Binding}">
                                <Image Source="{Binding Path}" Stretch="UniformToFill"/>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>