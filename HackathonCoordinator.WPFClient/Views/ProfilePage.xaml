<Page x:Class="HackathonCoordinator.WPFClient.Views.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:HackathonCoordinator.WPFClient.ViewModels"
      xmlns:converters="clr-namespace:HackathonCoordinator.WPFClient.Converters"
      Background="#FAFAFA">

    <Page.DataContext>
        <vm:ProfileViewModel/>
    </Page.DataContext>

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:BoolToBrushConverter x:Key="BoolToBrushConverter"/>

        <!-- стиль круглой кнопки -->
        <Style x:Key="RoundIconButton" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="15"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Border Background="White"
                CornerRadius="15"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                Padding="30"
                Width="500"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10">

                <!-- Фото профиля -->
                <Grid HorizontalAlignment="Center" Margin="0,0,0,20">
                    <Border Width="100" Height="100" CornerRadius="50" BorderBrush="#CCCCCC" BorderThickness="2">
                        <Image Source="{Binding CurrentIconPath}" Stretch="UniformToFill" />
                    </Border>

                    <!-- Иконка редактирования -->
                    <Button Content="🖉"
                            ToolTip="Изменить иконку"
                            Width="30" Height="30"
                            FontSize="16"
                            Background="#2196F3"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            VerticalAlignment="Bottom"
                            HorizontalAlignment="Right"
                            Margin="0,0,5,5"
                            Command="{Binding ChangeIconCommand}"
                            Style="{StaticResource RoundIconButton}"/>
                </Grid>

                <!-- Информация о пользователе -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,15">
                    <TextBlock Text="{Binding Username}" FontSize="18" FontWeight="Bold" Foreground="#333" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Email}" FontSize="14" Foreground="#666" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TeamName, StringFormat='Команда: {0}'}"
                               FontSize="14" Foreground="#666"
                               HorizontalAlignment="Center"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Редактирование имени -->
                <TextBlock Text="Изменить имя пользователя:" FontWeight="Bold" Foreground="#444" />
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Width="250" Height="35"
                         Padding="8"
                         Margin="0,5,0,15"
                         FontSize="14"/>

                <!-- Кнопки действий -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                    <Button Content="Сохранить изменения"
                            Command="{Binding SaveProfileCommand}"
                            Width="180" Height="40"
                            Margin="0,0,10,0"
                            Background="#4CAF50"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"/>
                    <Button Content="Выйти"
                            Command="{Binding LogoutCommand}"
                            Width="100" Height="40"
                            Background="#E53935"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"/>
                </StackPanel>

                <!-- Заглушка для темы -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <TextBlock Text="Тема: " FontSize="14" VerticalAlignment="Center"/>
                    <ComboBox Width="120" SelectedIndex="0" Margin="10,0,0,0">
                        <ComboBoxItem Content="Светлая"/>
                        <ComboBoxItem Content="Тёмная (в разработке)" IsEnabled="False"/>
                    </ComboBox>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- Панель выбора иконок -->
        <Border Background="#F9F9F9"
                CornerRadius="10"
                BorderBrush="#CCCCCC"
                BorderThickness="1"
                Padding="5"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="{Binding IsIconPanelVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                Height="150" Width="170">

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding AvailableIcons}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Width="60" Height="60"
                                    Margin="5"
                                    BorderBrush="{Binding IsSelected, Converter={StaticResource BoolToBrushConverter}}"
                                    BorderThickness="2"
                                    Command="{Binding DataContext.SelectIconCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                    CommandParameter="{Binding}">
                                <Image Source="{Binding Path}" Stretch="UniformToFill"/>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
