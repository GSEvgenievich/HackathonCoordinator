<Page x:Class="HackathonCoordinator.WPFClient.Views.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:HackathonCoordinator.WPFClient.ViewModels"
      xmlns:uc="clr-namespace:HackathonCoordinator.WPFClient.UserControls"
      Title="Профиль"
      Unloaded="Page_Unloaded">

    <Page.DataContext>
        <vm:ProfileViewModel/>
    </Page.DataContext>

    <Grid Margin="20">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Заголовок с навигацией и кнопкой выхода -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                    <DockPanel VerticalAlignment="Center">
                        <Button Content="← Назад" 
                                IsCancel="True"
                                Visibility="{Binding IsOwnProfile, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                Command="{Binding BackCommand}"
                                Style="{StaticResource NavigationButton}"
                                Margin="0,0,20,0"/>

                        <Button Content="🚪 Выйти"
                                Command="{Binding LogoutCommand}"
                                Style="{StaticResource SecondaryButton}"
                                BorderBrush="{DynamicResource DangerBrush}"
                                Foreground="{DynamicResource DangerBrush}"
                                DockPanel.Dock="Right"
                                Padding="16,10"
                                Visibility="{Binding IsOwnProfile, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <StackPanel>
                            <TextBlock Text="{Binding PageTitle}" 
                                       Style="{StaticResource PageHeaderStyle}"/>
                            <TextBlock Text="{Binding PageSubtitle}"
                                       Style="{StaticResource PageSubtitleStyle}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Основная информация о пользователе -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Аватар с кнопкой редактирования -->
                        <Grid Grid.Column="0" 
                              Width="130"
                              Height="130"
                              Margin="0,0,30,0"
                              VerticalAlignment="Center">
                            <uc:RoundAvatar Size="120" 
                                            x:Name="MainAvatar"
                                            Source="{Binding User.IconPath, UpdateSourceTrigger=PropertyChanged}"
                                            BorderBrush="{DynamicResource BorderColor}"
                                            BorderThickness="3"/>

                            <!-- Кнопка редактирования иконки наезжает на аватар -->
                            <Button Content="✏️"
                                    Command="{Binding ChangeIconCommand}"
                                    Style="{StaticResource RoundIconButton}"
                                    VerticalAlignment="Bottom"
                                    HorizontalAlignment="Right"
                                    Margin="0,0,5,5"
                                    Width="36"
                                    Height="36"
                                    FontSize="18"
                                    Visibility="{Binding IsOwnProfile, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </Grid>

                        <!-- Информация -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <!-- Имя пользователя с редактированием -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,5">
                                <TextBlock Text="{Binding User.Username}" 
                                           FontSize="28" 
                                           FontWeight="Bold" 
                                           Foreground="{DynamicResource TextColor}"
                                           Visibility="{Binding IsOwnProfile, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                                <StackPanel Orientation="Horizontal" 
                                            Visibility="{Binding IsOwnProfile, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBox Text="{Binding EditUsername, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ModernTextBox}"
                                             Width="280"
                                             FontSize="24"
                                             FontWeight="Bold"/>
                                    <Button Content="💾"
                                            Command="{Binding SaveUsernameCommand}"
                                            Style="{StaticResource IconButton}"
                                            Width="36"
                                            Height="36"
                                            Margin="10,0,0,0"
                                            ToolTip="Сохранить имя"/>
                                </StackPanel>
                            </StackPanel>

                            <TextBlock Text="{Binding User.Email}" 
                                       Style="{StaticResource BodyLargeStyle}"
                                       Margin="0,5,0,10"/>

                            <!-- Роль и должность -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Border Background="{Binding User.RoleId, Converter={StaticResource RoleToBrushConverter}}"
                                        CornerRadius="8"
                                        Padding="12,6"
                                        Margin="0,0,10,0">
                                    <TextBlock Text="{Binding User.RoleDisplay}"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Foreground="White"/>
                                </Border>

                                <!-- Свой профиль: выбор должности -->
                                <ComboBox ItemsSource="{Binding AvailablePositions}"
                                          SelectedItem="{Binding SelectedPosition}"
                                          DisplayMemberPath="Name"
                                          Style="{StaticResource ModernComboBox}"
                                          Width="180"
                                          Height="34"
                                          Visibility="{Binding IsOwnProfile, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                <!-- Чужой профиль: отображение должности -->
                                <Border Background="{DynamicResource PrimaryBrush}"
                                        CornerRadius="8"
                                        Padding="12,6"
                                        Visibility="{Binding IsOwnProfile, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                    <TextBlock Text="{Binding User.PositionName, FallbackValue='Должность не указана'}"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Foreground="White"/>
                                </Border>
                            </StackPanel>

                            <!-- Команда -->
                            <TextBlock Text="{Binding User.TeamName, StringFormat='🏃 Команда: {0}'}"
                                       Style="{StaticResource BodyTextStyle}"
                                       Margin="0,0,0,8"
                                       Visibility="{Binding User.TeamName, Converter={StaticResource NullToVisibilityConverter}}"/>

                            <!-- GitHub -->
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔗 GitHub: "
                                           Style="{StaticResource BodyTextStyle}"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding User.GitHubStatus}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
                                            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding User.GitHubUsername}" Value="{x:Null}">
                                                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding User.GitHubUsername}" Value="">
                                                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <Button Content="{Binding GitHubButtonText}"
                                        Command="{Binding LinkGitHubCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="15,0,0,0"
                                        Padding="12,6"
                                        FontSize="12"
                                        Visibility="{Binding IsOwnProfile, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Результаты соревнований -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20"
                        Visibility="{Binding HasResults, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="🏆 Результаты участия в соревнованиях"
                                   Style="{StaticResource SectionHeaderStyle}"
                                   Margin="0,0,0,15"/>

                        <ItemsControl ItemsSource="{Binding User.Results}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource InteractiveCardStyle}" Margin="0,0,0,10">
                                        <Border.InputBindings>
                                            <MouseBinding Gesture="LeftClick"
                                                          Command="{Binding DataContext.ViewTeamCompositionCommand, 
                                                              RelativeSource={RelativeSource AncestorType=Page}}"
                                                          CommandParameter="{Binding}"/>
                                        </Border.InputBindings>
                                        <Grid Margin="15">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Название соревнования и место -->
                                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                                                <TextBlock Text="{Binding CompetitionName}"
                                                           Style="{StaticResource BodyLargeStyle}"
                                                           FontWeight="SemiBold"
                                                           FontSize="18"/>
                                                <Border Background="{Binding Place, Converter={StaticResource PlaceToBrushConverter}}"
                                                        CornerRadius="8"
                                                        Padding="10,4"
                                                        Margin="12,0,0,0">
                                                    <TextBlock Text="{Binding PlaceDisplay}"
                                                               FontSize="14"
                                                               FontWeight="Bold"
                                                               Foreground="White"/>
                                                </Border>
                                            </StackPanel>

                                            <TextBlock Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right"
                                                       Text="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy}'}"
                                                       Style="{StaticResource CaptainIconStyle}"/>

                                            <!-- Команда -->
                                            <TextBlock Grid.Row="1" Grid.Column="0"
                                                       Text="{Binding TeamName, StringFormat='🏃 Команда: {0}'}"
                                                       Style="{StaticResource BodySecondaryStyle}"
                                                       Margin="0,10,0,10"/>

                                            <!-- Кнопка просмотра состава -->
                                            <Button Grid.Row="2" Grid.Column="0"
                                                    Content="👥 Посмотреть состав команды"
                                                    Command="{Binding DataContext.ViewTeamCompositionCommand, 
                                                              RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource SecondaryButton}"
                                                    HorizontalAlignment="Left"
                                                    Padding="12,6"/>

                                            <!-- Комментарий -->
                                            <TextBlock Grid.Row="2" Grid.Column="1"
                                                       Text="{Binding Comment}"
                                                       Style="{StaticResource CaptionSecondaryStyle}"
                                                       TextAlignment="Right"
                                                       TextWrapping="Wrap"
                                                       MaxWidth="200"
                                                       Visibility="{Binding Comment, Converter={StaticResource NullToVisibilityConverter}}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Сообщение когда нет результатов -->
                <Border Style="{StaticResource CardStyle}"
                        Visibility="{Binding HasNoResults, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" Margin="40">
                        <TextBlock Text="🏆"
                                   FontSize="48"
                                   HorizontalAlignment="Center"
                                   Opacity="0.5"/>
                        <TextBlock Text="Пользователь еще не участвовал в соревнованиях"
                                   Style="{StaticResource BodyTextStyle}"
                                   HorizontalAlignment="Center"
                                   Margin="0,15,0,0"
                                   Foreground="{DynamicResource TextSecondaryColor}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Панель выбора иконок -->
        <Border Background="{DynamicResource CardBackground}"
                CornerRadius="12"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1"
                Padding="10"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="{Binding IsIconPanelVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                Width="250"
                Height="250">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.2"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding AvailableIcons}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button BorderThickness="0"
                                    Command="{Binding DataContext.SelectIconCommand, 
                                              RelativeSource={RelativeSource AncestorType=Page}}"
                                    CommandParameter="{Binding}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource HoverColor}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <uc:RoundAvatar Size="100" 
                                                Source="{Binding Path}"
                                                BorderBrush="{DynamicResource PrimaryBrush}"
                                                BorderThickness="{Binding IsSelected, Converter={StaticResource BoolToThicknessConverter}}"/>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>