<Page x:Class="HackathonCoordinator.WPFClient.Views.CompetitionResultsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:HackathonCoordinator.WPFClient.ViewModels"
      Title="Результаты соревнования"
      Unloaded="Page_Unloaded"
      Background="Transparent">

    <Page.DataContext>
        <vm:CompetitionResultsViewModel/>
    </Page.DataContext>

    <Grid x:Name="MainGrid" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
            <DockPanel VerticalAlignment="Center">
                <Button Content="← Назад" 
                        IsCancel="True"
                        Command="{Binding BackCommand}"
                        Style="{StaticResource NavigationButton}"
                        Margin="0,0,20,0"/>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <!-- Кнопка экспорта -->
                    <Button Content="{Binding ExportButtonText}"
                            Command="{Binding ExportResultsCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Padding="20,12"
                            Margin="0,0,10,0"
                            Visibility="{Binding HasExistingResults, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- Кнопка сохранения -->
                    <Button Content="{Binding SaveButtonText}"
                            Command="{Binding SaveResultsCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Padding="20,12"
                            Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>

                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding PageTitle}" 
                                   Style="{StaticResource PageHeaderStyle}"/>
                        <Border Background="Transparent"
                                    Margin="12,0,0,0"
                                    Cursor="Help"
                                    Visibility="{Binding IsOrganizer, 
                                            Converter={StaticResource BoolToVisibilityConverter}}">
                                <Border.ToolTip>
                                    <Border Background="{DynamicResource CardBackground}"
                                            BorderBrush="{DynamicResource BorderColor}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="12"
                                            MaxWidth="300">
                                        <StackPanel>
                                            <TextBlock Text="📋 Информация о результатах" 
                                                               FontWeight="Bold" 
                                                               FontSize="13"
                                                               Margin="0,0,0,10"/>
                                            <TextBlock Text="{Binding Competition.ResultsInfo}" 
                                                            FontSize="11"
                                                            Margin="0,2,0,8"/>
                                        </StackPanel>
                                    </Border>
                                </Border.ToolTip>
                                <TextBlock Text="ℹ️" 
                                           FontSize="16" 
                                           Foreground="{DynamicResource PrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding CompetitionName, StringFormat='Соревнование: {0}'}"
                               Style="{StaticResource PageSubtitleStyle}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Список команд -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto"
                      x:Name="MainScrollViewer"
                      Background="Transparent">
            <StackPanel x:Name="TeamsPanel" 
                        Background="Transparent"
                        AllowDrop="False"/>
        </ScrollViewer>

        <!-- Нижняя панель управления (только для режима редактирования) -->
        <StackPanel Grid.Row="2" Margin="0,15,0,0"
                    Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="⬆ Переместить вверх" 
                        Margin="5"
                        Command="{Binding MoveUpCommand}"
                        Style="{StaticResource SecondaryButton}"
                        IsEnabled="{Binding CanMoveUp}"/>
                <Button Content="⬇ Переместить вниз" 
                        Margin="5"
                        Command="{Binding MoveDownCommand}"
                        Style="{StaticResource SecondaryButton}"
                        IsEnabled="{Binding CanMoveDown}"/>
            </StackPanel>
        </StackPanel>

        <!-- Canvas для перетаскиваемой копии (только для режима редактирования) -->
        <Canvas x:Name="DragCanvas" 
                Grid.Row="0" 
                Grid.RowSpan="3"
                Background="Transparent"
                IsHitTestVisible="False"
                Visibility="Collapsed">
            <Border x:Name="DragPreview"
                    Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource PrimaryBrush}"
                    BorderThickness="2"
                    CornerRadius="8"
                    Opacity="0.95"
                    Width="Auto"
                    Height="80">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.3" Color="Black"/>
                </Border.Effect>
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" 
                            Background="{DynamicResource PrimaryBrush}" 
                            CornerRadius="25"
                            Width="40" 
                            Height="40"
                            HorizontalAlignment="Left">
                        <TextBlock x:Name="DragPreviewPosition" 
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock x:Name="DragPreviewName" 
                               Grid.Column="1" 
                               FontSize="16"
                               VerticalAlignment="Center"
                               Margin="10,0"
                               Foreground="{DynamicResource TextColor}"/>

                    <Button Grid.Column="2" 
                            Content="💬 Комментарий"
                            Background="{DynamicResource PrimaryBrush}"
                            Foreground="White"
                            BorderThickness="0"
                            Padding="10,5"
                            IsHitTestVisible="False"/>
                </Grid>
            </Border>
        </Canvas>

        <!-- Диалог комментария -->
        <Border Style="{StaticResource ModalOverlayStyle}" Grid.RowSpan="3"
                Visibility="{Binding ShowCommentDialog, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Style="{StaticResource ModalDialogStyle}" Width="450">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="💬"
                                   FontSize="20"
                                   Margin="0,0,10,0"/>
                        <TextBlock Text="Комментарий для команды"
                                   Style="{StaticResource ModalTitleStyle}"/>
                    </StackPanel>

                    <TextBlock Text="{Binding SelectedTeam.TeamName, StringFormat='Команда: {0}'}"
                               Style="{StaticResource BodyTextStyle}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"/>

                    <TextBox Text="{Binding CommentText}"
                             Style="{StaticResource ModernTextBox}"
                             Height="100"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             Tag="Введите комментарий..."
                             IsReadOnly="{Binding IsViewMode}"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="Отмена"
                                Command="{Binding CancelCommentCommand}"
                                Style="{StaticResource ModalSecondaryButton}"
                                Margin="0,0,10,0"/>
                        <Button Content="Сохранить"
                                Command="{Binding SaveCommentCommand}"
                                Style="{StaticResource ModalPrimaryButton}"
                                Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Page>