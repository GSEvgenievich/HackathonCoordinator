<Page x:Class="HackathonCoordinator.WPFClient.Views.UsersManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:HackathonCoordinator.WPFClient.ViewModels"
      Title="Управление участниками"
      Unloaded="Page_Unloaded"
      Loaded="Page_Loaded">

    <Page.DataContext>
        <vm:UsersManagementViewModel/>
    </Page.DataContext>

    <Grid Margin="20">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Заголовок -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="← Назад" 
                                Command="{Binding BackCommand}"
                                Style="{StaticResource NavigationButton}"
                                Margin="0,0,20,0"/>

                        <StackPanel>
                            <TextBlock Text="👥 Управление участниками" 
                                   Style="{StaticResource PageHeaderStyle}"/>
                            <TextBlock Text="Просмотр и управление всеми участниками системы"
                                   Style="{StaticResource PageSubtitleStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Статистика -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="👤 ВСЕГО УЧАСТНИКОВ"
                                   Style="{StaticResource StatsHeaderStyle}"/>
                            <TextBlock Text="{Binding TotalUsersCount}"
                                   Style="{StaticResource StatsValueStyle}"/>
                        </StackPanel>

                        <Rectangle Grid.Column="1" Style="{StaticResource VerticalDividerStyle}"/>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="🏃 В КОМАНДАХ"
                                   Style="{StaticResource StatsHeaderStyle}"/>
                            <TextBlock Text="{Binding UsersInTeamsCount}"
                                   Style="{StaticResource StatsValueStyle}"/>
                        </StackPanel>

                        <Rectangle Grid.Column="3" Style="{StaticResource VerticalDividerStyle}"/>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="🎯 БЕЗ КОМАНДЫ"
                                   Style="{StaticResource StatsHeaderStyle}"/>
                            <TextBlock Text="{Binding UsersWithoutTeamCount}"
                                   Style="{StaticResource StatsValueStyle}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Кнопка управления должностями (только для админа) -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20"
                        Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Button Content="📋 Управление должностями"
                            Command="{Binding TogglePositionsPanelCommand}"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Left"
                            Padding="20,10"/>
                </Border>

                <!-- Панель управления должностями -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20"
                        Visibility="{Binding ShowPositionsPanel, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="📋 Управление должностями"
                                   Style="{StaticResource SectionHeaderStyle}"
                                   Margin="0,0,0,15"/>

                        <!-- Создание новой должности -->
                        <Border Style="{StaticResource StatsContainerStyle}" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="➕ Создать новую должность"
                                           Style="{StaticResource StatsHeaderStyle}"
                                           Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding NewPositionName, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ModernTextBox}"
                                             Tag="Название должности"/>
                                    <Button Grid.Column="1"
                                            Content="Создать"
                                            Command="{Binding CreatePositionCommand}"
                                            Style="{StaticResource PrimaryButton}"
                                            Margin="10,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Список должностей -->
                        <TextBlock Text="📋 Существующие должности"
                                   Style="{StaticResource StatsHeaderStyle}"
                                   Margin="0,0,0,10"/>

                        <ItemsControl ItemsSource="{Binding AllPositions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource MemberCardStyle}" Margin="0,0,0,5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Название должности -->
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Name}"
                                                           Style="{StaticResource BodyTextStyle}"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Text="Базовая должность (нельзя редактировать/удалить)"
                                                           Style="{StaticResource CaptionSecondaryStyle}"
                                                           Foreground="{DynamicResource TextSecondaryColor}"
                                                           Visibility="{Binding IsProtected, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            </StackPanel>

                                            <!-- Кнопки действий -->
                                            <StackPanel Grid.Column="1" 
                                                        Orientation="Horizontal"
                                                        Visibility="{Binding DataContext.IsAdmin, 
                                                                   Converter={StaticResource BoolToVisibilityConverter},
                                                                   RelativeSource={RelativeSource AncestorType=Page}}">

                                                <!-- Редактировать -->
                                                <Button Content="✏️"
                                                        Command="{Binding DataContext.EditPositionCommand,
                                                                  RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource IconButton}"
                                                        Margin="0,0,8,0"
                                                        ToolTip="Редактировать должность"
                                                        Visibility="{Binding IsProtected, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                                                <!-- Удалить -->
                                                <Button Content="🗑️"
                                                        Command="{Binding DataContext.DeletePositionCommand,
                                                                  RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource DangerIconButton}"
                                                        ToolTip="Удалить должность"
                                                        Visibility="{Binding IsProtected, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Поиск и фильтры -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="🔍 Поиск и фильтрация"
                               Style="{StaticResource SectionHeaderStyle}"
                               Margin="0,0,0,15"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Tag="Поиск по имени или email..."
                                 Margin="0,0,15,0"/>

                            <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding StatusFilters}"
                                  SelectedItem="{Binding SelectedStatusFilter}"
                                  DisplayMemberPath="Name"
                                  Style="{StaticResource ModernComboBox}"
                                  Width="180"
                                  Margin="0,0,15,0"/>

                            <Button Grid.Column="2"
                                Content="🗑️ Сбросить"
                                Command="{Binding ResetFiltersCommand}"
                                Style="{StaticResource SecondaryButton}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Список участников -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="📋 Список участников"
                               Style="{StaticResource SectionHeaderStyle}"
                               Margin="0,0,0,15"/>

                        <ScrollViewer MaxHeight="500" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding FilteredUsers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource InteractiveCardStyle}" Margin="0,0,0,10">
                                            <Border.InputBindings>
                                                <MouseBinding Gesture="LeftClick"
                                                              Command="{Binding DataContext.ViewUserCommand, 
                                                                  RelativeSource={RelativeSource AncestorType=Page}}"
                                                              CommandParameter="{Binding}"/>
                                            </Border.InputBindings>
                                            <Grid Margin="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Аватар -->
                                                <Border Width="50" Height="50" CornerRadius="25"
                                                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                                                    <Image Source="{Binding IconPath}" Stretch="UniformToFill"/>
                                                </Border>

                                                <!-- Информация -->
                                                <StackPanel Grid.Column="1" Margin="15,0">
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                                        <TextBlock Text="{Binding Username}"
                                                               Style="{StaticResource BodyTextStyle}"
                                                               FontWeight="SemiBold"
                                                               FontSize="14"/>

                                                        <Border Background="{Binding RoleId, Converter={StaticResource RoleToBrushConverter}}"
                                                            CornerRadius="8"
                                                            Padding="6,2"
                                                            Margin="10,0,0,0"
                                                            VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding RoleName}"
                                                                   FontSize="10"
                                                                   FontWeight="Bold"
                                                                   Foreground="White"/>
                                                        </Border>

                                                        <Border Background="{DynamicResource PrimaryBrush}"
                                                            CornerRadius="8"
                                                            Padding="6,2"
                                                            Margin="5,0,0,0"
                                                            VerticalAlignment="Center"
                                                            Visibility="{Binding PositionName, Converter={StaticResource NullToVisibilityConverter}}">
                                                            <TextBlock Text="{Binding PositionName}"
                                                                   FontSize="10"
                                                                   FontWeight="Bold"
                                                                   Foreground="White"/>
                                                        </Border>
                                                    </StackPanel>

                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="📧"
                                                               Style="{StaticResource MetaIconStyle}"/>
                                                        <TextBlock Text="{Binding Email}"
                                                               Style="{StaticResource MetaTextStyle}"
                                                               Margin="0,0,15,0"/>

                                                        <TextBlock Text="🔗"
                                                               Style="{StaticResource MetaIconStyle}"/>
                                                        <TextBlock Text="{Binding GitHubStatus}"
                                                               Style="{StaticResource MetaTextStyle}"
                                                               Margin="0,0,15,0"/>

                                                        <TextBlock Text="🏃"
                                                               Style="{StaticResource MetaIconStyle}"/>
                                                        <TextBlock Text="{Binding TeamStatus}"
                                                               Style="{StaticResource MetaTextStyle}"/>
                                                    </StackPanel>

                                                    <TextBlock Text="{Binding TeamInfo}"
                                                           Style="{StaticResource CaptionSecondaryStyle}"
                                                           Margin="0,5,0,0"
                                                           Visibility="{Binding HasTeam, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                </StackPanel>

                                                <!-- Действия -->
                                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                    <!-- Кнопка назначения организатором (только для админа) -->
                                                    <Button Content="👑"
                                                            Command="{Binding DataContext.ManageRoleCommand, 
                                                                      RelativeSource={RelativeSource AncestorType=Page}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource IconButton}"
                                                            ToolTip="{Binding RoleId, Converter={StaticResource RoleToManageTooltipConverter}}"
                                                            Margin="0,0,10,0"
                                                            Visibility="{Binding DataContext.IsAdmin, 
                                                                         Converter={StaticResource BoolToVisibilityConverter},
                                                                         RelativeSource={RelativeSource AncestorType=Page}}"/>

                                                    <!-- Кнопка удаления -->
                                                    <Button Content="🗑️"
                                                            Command="{Binding DataContext.DeleteUserCommand, 
                                                                      RelativeSource={RelativeSource AncestorType=Page}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource DangerIconButton}"
                                                            ToolTip="Удалить учетную запись"
                                                            Visibility="{Binding DataContext.IsAdmin, 
                                                                         Converter={StaticResource BoolToVisibilityConverter},
                                                                         RelativeSource={RelativeSource AncestorType=Page}}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <TextBlock Text="🎯 Участники не найдены"
                               Style="{StaticResource BodyTextStyle}"
                               HorizontalAlignment="Center"
                               Margin="0,20,0,0"
                               Visibility="{Binding HasNoUsers, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Модальное окно подтверждения удаления -->
        <Border Style="{StaticResource ModalOverlayStyle}"
                Visibility="{Binding ShowDeleteDialog, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Style="{StaticResource ModalDialogStyle}" Width="450">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="⚠️"
                                   FontSize="20"
                                   Margin="0,0,10,0"/>
                        <TextBlock Text="Удаление учетной записи"
                               Style="{StaticResource ModalTitleStyle}"/>
                    </StackPanel>

                    <TextBlock Text="Вы уверены, что хотите удалить учетную запись участника?"
                           Style="{StaticResource ModalDescriptionStyle}"
                           Margin="0,0,0,10"/>

                    <Border Style="{StaticResource StatsContainerStyle}" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="{Binding UserToDelete.Username}"
                                   Style="{StaticResource BodyTextStyle}"
                                   FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding UserToDelete.Email}"
                                   Style="{StaticResource CaptionSecondaryStyle}"/>
                            <TextBlock Text="{Binding UserToDelete.TeamInfo}"
                                   Style="{StaticResource CaptionSecondaryStyle}"
                                   Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Это действие нельзя отменить! Все данные участника будут удалены."
                           Style="{StaticResource CaptionSecondaryStyle}"
                           Foreground="{DynamicResource DangerBrush}"
                           FontWeight="SemiBold"
                           Margin="0,0,0,20"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Отмена"
                                Command="{Binding CancelDeleteCommand}"
                                Style="{StaticResource ModalSecondaryButton}"
                                Margin="0,0,10,0"/>
                        <Button Content="Удалить"
                                Command="{Binding ConfirmDeleteCommand}"
                                Style="{StaticResource ModalDangerButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- Модальное окно управления ролью -->
        <Border Style="{StaticResource ModalOverlayStyle}"
                Visibility="{Binding ShowManageRoleDialog, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Style="{StaticResource ModalDialogStyle}" Width="450">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="👑"
                                   FontSize="20"
                                   Margin="0,0,10,0"/>
                        <TextBlock Text="Управление ролью"
                                Style="{StaticResource ModalTitleStyle}"/>
                    </StackPanel>

                    <TextBlock Text="{Binding RoleManageMessage}"
                               Style="{StaticResource ModalDescriptionStyle}"
                               Margin="0,0,0,10"/>

                    <Border Style="{StaticResource StatsContainerStyle}" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="{Binding UserToManage.Username}"
                                       Style="{StaticResource BodyTextStyle}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding UserToManage.Email}"
                                    Style="{StaticResource CaptionSecondaryStyle}"/>
                            <TextBlock Text="{Binding UserToManage.RoleName, StringFormat='Текущая роль: {0}'}"
                                       Style="{StaticResource CaptionSecondaryStyle}"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="Отмена"
                                Command="{Binding CancelManageRoleCommand}"
                                Style="{StaticResource ModalSecondaryButton}"
                                Margin="0,0,10,0"/>

                        <Button Content="Назначить организатором"
                                Command="{Binding ConfirmMakeOrganizerCommand}"
                                Style="{StaticResource ModalPrimaryButton}"
                                Visibility="{Binding IsUserNotOrganizer, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <Button Content="Снять права организатора"
                                Command="{Binding ConfirmRemoveOrganizerCommand}"
                                Style="{StaticResource ModalDangerButton}"
                                Visibility="{Binding IsUserOrganizer, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Page>