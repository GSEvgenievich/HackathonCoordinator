<Page x:Class="HackathonCoordinator.WPFClient.Views.ProjectPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:HackathonCoordinator.WPFClient.ViewModels"
      xmlns:converters="clr-namespace:HackathonCoordinator.WPFClient.Converters"
      Title="Проект">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:BoolToArrowConverter x:Key="BoolToArrowConverter"/>

        <!-- Стиль для заголовка секции задач -->
        <Style x:Key="TaskSectionHeaderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Page.Resources>

    <Page.DataContext>
        <vm:ProjectViewModel/>
    </Page.DataContext>

    <Grid Margin="30">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Заголовок и кнопка возврата -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Button Content="← Назад к команде" 
                            Command="{Binding BackCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,20,0"/>

                    <TextBlock Text="{Binding Project.Name}" 
                               FontSize="26" 
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextColor}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Информация о проекте -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="Информация о проекте"
                                       FontWeight="SemiBold"
                                       FontSize="18"
                                       Foreground="{DynamicResource TextColor}"/>

                            <!-- Кнопка редактирования (только для капитана) -->
                            <Button Content="✏️ Редактировать"
                                    Command="{Binding EditProjectCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="20,0,0,0"
                                    Padding="10,6"
                                    Visibility="{Binding IsCaptain, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            
                            <!-- Кнопка чата проекта -->
                            <Button Content="💬 Чат проекта"
                                    Command="{Binding OpenChatCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="20,0,0,0"
                                    Padding="10,6"/>
                        </StackPanel>

                        <!-- Описание проекта -->
                        <TextBlock Text="{Binding Project.Description}"
                                   Style="{StaticResource BodyTextStyle}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,15"/>

                        <!-- Детали проекта -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,30,0">
                                <TextBlock Text="Дата создания:"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextColor}"
                                           Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding Project.CreatedAt, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"
                                           Style="{StaticResource BodyTextStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,30,0">
                                <TextBlock Text="GitHub репозиторий:"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextColor}"
                                           Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding Project.GithubRepoName}"
                                           Style="{StaticResource BodyTextStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="0,0,30,0">
                                <TextBlock Text="Всего задач:"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextColor}"
                                           Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding TotalTasksCount}"
                                           Style="{StaticResource BodyTextStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3">
                                <TextBlock Text="Завершено:"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextColor}"
                                           Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding CompletedTasksCount}"
                                           Style="{StaticResource BodyTextStyle}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Задачи проекта -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="Задачи проекта"
                                       FontWeight="SemiBold"
                                       FontSize="18"
                                       Foreground="{DynamicResource TextColor}"/>

                            <!-- Кнопка создания задачи (только для капитана) -->
                            <Button Content="＋ Новая задача"
                                    Command="{Binding CreateTaskCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="20,0,0,0"
                                    Visibility="{Binding IsCaptain, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>

                        <!-- Секции задач по статусам -->
                        <ItemsControl ItemsSource="{Binding TaskSections}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,10">
                                        <!-- Заголовок секции -->
                                        <Border Style="{StaticResource TaskSectionHeaderStyle}">
                                            <Border.InputBindings>
                                                <MouseBinding Gesture="LeftClick" 
                                                              Command="{Binding DataContext.ToggleSectionCommand, 
                                                                                RelativeSource={RelativeSource AncestorType=Page}}"
                                                              CommandParameter="{Binding StatusId}"/>
                                            </Border.InputBindings>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Название статуса и количество -->
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding StatusName}" 
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextColor}"
                                                               FontSize="16"/>
                                                    <TextBlock Text="{Binding Tasks.Count, StringFormat=' ({0})'}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextSecondaryColor}"
                                                               FontSize="16"
                                                               Margin="5,0,0,0"/>
                                                </StackPanel>

                                                <!-- Стрелка раскрытия -->
                                                <TextBlock Grid.Column="1" 
                                                           Text="{Binding IsExpanded, Converter={x:Static converters:BoolToArrowConverter.Instance}}"
                                                           FontSize="16"
                                                           Foreground="{DynamicResource TextSecondaryColor}"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>

                                        <!-- Список задач (раскрывается) -->
                                        <ItemsControl ItemsSource="{Binding Tasks}"
                                                      Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}"
                                                      Margin="10,5,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{DynamicResource ControlBackground}"
                                                            BorderBrush="{DynamicResource BorderColor}"
                                                            BorderThickness="1"
                                                            CornerRadius="6"
                                                            Margin="0,0,0,5"
                                                            Padding="12"
                                                            Cursor="Hand">
                                                        <Border.InputBindings>
                                                            <MouseBinding Gesture="LeftClick"
                                                                          Command="{Binding DataContext.OpenTaskCommand, 
                                                                                            RelativeSource={RelativeSource AncestorType=Page}}"
                                                                          CommandParameter="{Binding}"/>
                                                        </Border.InputBindings>

                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- Информация о задаче -->
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Title}" 
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource TextColor}"
                                                                           Margin="0,0,0,5"/>

                                                                <TextBlock Text="{Binding Description}"
                                                                           Style="{StaticResource BodyTextStyle}"
                                                                           TextWrapping="Wrap"
                                                                           Margin="0,0,0,5"/>

                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="Тип: "
                                                                               Style="{StaticResource BodyTextStyle}"/>
                                                                    <TextBlock Text="{Binding TypeName}"
                                                                               Style="{StaticResource BodyTextStyle}"
                                                                               FontWeight="SemiBold"/>

                                                                    <TextBlock Text=" • Назначена: "
                                                                               Style="{StaticResource BodyTextStyle}"
                                                                               Margin="10,0,0,0"/>
                                                                    <TextBlock Text="{Binding AssignedToUsername, FallbackValue='Не назначена'}"
                                                                               Style="{StaticResource BodyTextStyle}"
                                                                               FontWeight="SemiBold"/>

                                                                    <TextBlock Text=" • Дедлайн: "
                                                                               Style="{StaticResource BodyTextStyle}"
                                                                               Margin="10,0,0,0"/>
                                                                    <TextBlock Text="{Binding Deadline, StringFormat='{}{0:dd.MM.yyyy}'}"
                                                                               Style="{StaticResource BodyTextStyle}"
                                                                               FontWeight="SemiBold"/>
                                                                </StackPanel>
                                                            </StackPanel>

                                                            <!-- Действия с задачей -->
                                                            <StackPanel Grid.Column="1" 
                                                                        Orientation="Horizontal"
                                                                        Visibility="{Binding DataContext.IsCaptain, 
                                                                                            Converter={StaticResource BoolToVisibilityConverter},
                                                                                            RelativeSource={RelativeSource AncestorType=Page}}">
                                                                <Button Content="✏️"
                                                                        Command="{Binding DataContext.EditTaskCommand, 
                                                                                         RelativeSource={RelativeSource AncestorType=Page}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource RoundIconButton}"
                                                                        Margin="0,0,5,0"
                                                                        ToolTip="Редактировать"/>

                                                                                                        <Button Content="🗑️"
                                                                        Command="{Binding DataContext.DeleteTaskCommand, 
                                                                                         RelativeSource={RelativeSource AncestorType=Page}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource RoundIconButton}"
                                                                        Background="{DynamicResource DangerBrush}"
                                                                        ToolTip="Удалить"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Сообщение если нет задач -->
                        <TextBlock Text="В проекте пока нет задач"
                                   Style="{StaticResource BodyTextStyle}"
                                   HorizontalAlignment="Center"
                                   Margin="0,20,0,0"
                                   Visibility="{Binding HasTasks, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>