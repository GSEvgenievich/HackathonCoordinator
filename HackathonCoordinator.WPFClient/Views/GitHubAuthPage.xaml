<Page x:Class="HackathonCoordinator.WPFClient.Views.GitHubAuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:HackathonCoordinator.WPFClient.ViewModels"
      Title="Привязка GitHub"
      Unloaded="Page_Unloaded">

    <Page.DataContext>
        <vm:GitHubAuthViewModel/>
    </Page.DataContext>

    <Grid>
        <Border Style="{StaticResource CardStyle}"
                Padding="30"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Заголовок -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                    <TextBlock Text="Привязка GitHub аккаунта" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextColor}"/>
                    <TextBlock Text="Привяжите свой GitHub для доступа к репозиториям"
                               Style="{StaticResource BodyTextStyle}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Статус -->
                <Border BorderThickness="1"
                        CornerRadius="5"
                        Padding="15"
                        Margin="0,0,0,20">
                    <TextBlock Text="{Binding StatusMessage}"
                               Style="{StaticResource BodyTextStyle}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>
                </Border>

                <!-- Индикатор загрузки -->
                <ProgressBar IsIndeterminate="True"
                             Height="4"
                             Width="200"
                             Margin="0,0,0,20"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <!-- Поле для ввода кода -->
                <StackPanel Visibility="{Binding ShowCodeInput, Converter={StaticResource BoolToVisibilityConverter}}"
                            Margin="0,0,0,20">
                    <TextBlock Text="Введите код авторизации:"
                               Style="{StaticResource BodyTextStyle}"
                               Margin="0,0,0,5"/>
                    <TextBox Text="{Binding AuthorizationCode, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}"
                             Width="250"/>
                </StackPanel>

                <!-- Кнопки действий -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Начать привязку"
                            Command="{Binding StartOAuthCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,10,0"
                            IsEnabled="{Binding IsNotLoading}"/>

                    <Button Content="Подтвердить код"
                            Command="{Binding ConfirmCodeCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,10,0"
                            Visibility="{Binding ShowCodeInput, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <Button Content="Вернуться в профиль"
                            Command="{Binding GoToProfileCommand}"
                            Style="{StaticResource SecondaryButton}"/>
                </StackPanel>

                <!-- Успешная привязка -->
                <StackPanel HorizontalAlignment="Center" 
                            Margin="0,20,0,0"
                            Visibility="{Binding IsSuccess, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="✅ GitHub аккаунт успешно привязан!"
                               FontWeight="Bold"
                               Foreground="Green"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>