<Page x:Class="HackathonCoordinator.WPFClient.Views.TeamPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:HackathonCoordinator.WPFClient.Views"
      xmlns:vm="clr-namespace:HackathonCoordinator.WPFClient.ViewModels"
      Background="#FAFAFA">

    <Page.DataContext>
        <vm:TeamViewModel/>
    </Page.DataContext>

    <Grid Margin="20">
        <Border Background="White"
                CornerRadius="15"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                Padding="20"
                Effect="{DynamicResource ShadowEffect}">

            <StackPanel>
                <!-- Заголовок -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                    <TextBlock Text="{Binding TeamName}" 
                               FontSize="24" FontWeight="Bold" Foreground="#333" Margin="0,0,10,0"/>
                    <TextBlock Text="•" FontSize="22" Foreground="#999" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding InviteCode, StringFormat='Код: {0}'}" 
                               FontSize="16" Foreground="#666"/>
                </StackPanel>

                <!-- Двухколоночный блок -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Участники (левая колонка) -->
                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <!-- margin эмулирует промежуток между колонками -->
                        <TextBlock Text="Участники команды" FontSize="18" FontWeight="Bold" Foreground="#444" Margin="0,0,0,10"/>
                        <Border BorderBrush="#F0F0F0" BorderThickness="1" CornerRadius="8" Padding="8" >
                            <ScrollViewer Height="200" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Members}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                                <Border Width="40" Height="40" CornerRadius="20" BorderBrush="#CCC" BorderThickness="1" Margin="0,0,10,0">
                                                    <Image Source="{Binding IconPath}" Stretch="UniformToFill"/>
                                                </Border>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Username}" FontSize="14" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding RoleName}" FontSize="12" Foreground="#888"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>

                    <!-- Проекты (правая колонка) -->
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Проекты" FontSize="18" FontWeight="Bold" Foreground="#444" Margin="0,0,0,10"/>
                        <Border BorderBrush="#F0F0F0" BorderThickness="1" CornerRadius="8" Padding="8">
                            <ScrollViewer Height="200" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Projects}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                                                <StackPanel>
                                                    <!-- Подстраивай поля под DTO: здесь Name + Description -->
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16"/>
                                                    <TextBlock Text="{Binding Description}" FontSize="13" Foreground="#666" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                                        <Button Content="Открыть проект"
                                                                Width="120" Height="30"
                                                                Margin="0,0,8,0"
                                                                Background="#2196F3" Foreground="White"
                                                                BorderThickness="0"
                                                                Command="{Binding DataContext.OpenProjectCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                CommandParameter="{Binding Id}"/>
                                                        <Button Content="Чат"
                                                                Width="80" Height="30"
                                                                Background="#607D8B" Foreground="White"
                                                                BorderThickness="0"
                                                                Command="{Binding DataContext.OpenProjectChatCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                CommandParameter="{Binding Id}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </Grid>


                <!-- Нижние кнопки -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button Content="💬 Чат команды"
                            Width="150" Height="40"
                            Background="#4CAF50"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Margin="0,0,10,0"
                            Command="{Binding OpenChatCommand}"/>
                    <Button Content="Покинуть команду"
                            Width="150" Height="40"
                            Background="#E53935"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Command="{Binding LeaveTeamCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
