<Page x:Class="HackathonCoordinator.WPFClient.Views.TeamPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:HackathonCoordinator.WPFClient.ViewModels"
      xmlns:behaviors="clr-namespace:HackathonCoordinator.WPFClient.Behaviors"
      xmlns:uc="clr-namespace:HackathonCoordinator.WPFClient.UserControls"
      Title="Команда"
      Unloaded="Page_Unloaded">

    <Page.DataContext>
        <vm:TeamViewModel/>
    </Page.DataContext>

    <Grid Margin="20">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Основная информация о команде -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,25">
                    <StackPanel>
                        <!-- Заголовок и навигация -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Button Content="← Назад"
                                    IsCancel="True" 
                                    Command="{Binding BackCommand}"
                                    Visibility="{Binding CanGoBack, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Style="{StaticResource NavigationButton}"
                                    Margin="0,0,20,0"/>

                            <StackPanel>
                                <TextBlock Text="{Binding TeamName}" 
                                           Style="{StaticResource PageHeaderStyle}"/>
                                <TextBlock Text="{Binding PageSubtitle}"
                                           Style="{StaticResource PageSubtitleStyle}"/>
                            </StackPanel>

                            <!-- Бейдж статуса -->
                            <Border Background="{Binding CompetitionStatusColor, Converter={StaticResource CompetitionStatusToBrushConverter}}"
                                    CornerRadius="12"
                                    Padding="10,5"
                                    Margin="20,0,0,0"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding IsArchived, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="{Binding CompetitionStatusText}"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Foreground="White"/>
                            </Border>
                        </StackPanel>

                        <!-- Баннер архива -->
                        <Border Background="{DynamicResource DangerBrush}"
                                CornerRadius="8"
                                Padding="12,8"
                                Margin="0,10,0,0"
                                Visibility="{Binding IsArchived, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="📦 " FontSize="16" Foreground="White"/>
                                <TextBlock Text="Соревнование находится в архиве. Редактирование недоступно."
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>
                            </StackPanel>
                        </Border>

                        <!-- Статистика команды -->
                        <Border Style="{StaticResource StatsContainerStyle}" Margin="0,10,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition MaxWidth="400"/>
                                    <ColumnDefinition MinWidth="420"/>
                                </Grid.ColumnDefinitions>

                                <!-- GitHub репозиторий -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="🔗 GitHub репозиторий"
                                              Style="{StaticResource StatsLabelStyle}"/>
                                    <DockPanel VerticalAlignment="Center">
                                        <Button Content="{Binding GitHubButtonText}" DockPanel.Dock="Right"
                                                Command="{Binding GitHubCommand}"
                                                Style="{StaticResource SecondaryButton}"
                                                Padding="8,4"
                                                Visibility="{Binding IsGitHubButtonVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <TextBox Text="{Binding GitHubRepoUrl, FallbackValue='Не подключен', Mode=OneWay}"
                                                 Style="{StaticResource ReadingTextBox}"
                                                 Margin="0 0 10 0"
                                                 VerticalAlignment="Center"
                                                 IsReadOnly="True"/>
                                    </DockPanel>
                                </StackPanel>

                                <Grid Grid.Column="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Разделитель -->
                                    <Rectangle Grid.Column="0" Margin="5 0" Style="{StaticResource VerticalDividerStyle}"/>

                                    <!-- Место (если результаты подведены) -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                                Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="🏆 МЕСТО"
                                                   HorizontalAlignment="Center"
                                                   Style="{StaticResource StatsHeaderStyle}"/>
                                        <TextBlock Text="{Binding PlaceDisplay}"
                                                   Style="{StaticResource StatsValueStyle}"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{Binding PlaceBrush}"/>
                                    </StackPanel>

                                    <!-- Разделитель -->
                                    <Rectangle Grid.Column="2" Margin="5 0" Style="{StaticResource VerticalDividerStyle}"/>
                                
                                    <!-- Задачи (только если не в архиве) -->
                                    <StackPanel Grid.Column="3" VerticalAlignment="Center"
                                                Visibility="{Binding IsArchived, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <TextBlock Text="📋 ЗАДАЧИ" 
                                                   HorizontalAlignment="Center"
                                                   Style="{StaticResource StatsHeaderStyle}"/>
                                        <TextBlock Text="{Binding TotalTasksCount, StringFormat='Всего: {0}'}"
                                                   HorizontalAlignment="Center"
                                                   Style="{StaticResource StatsValueStyle}"/>
                                    </StackPanel>

                                    <!-- Разделитель -->
                                    <Rectangle Grid.Column="4" Style="{StaticResource VerticalDividerStyle}" Margin="5 0"
                                              Visibility="{Binding IsArchived, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                                    <!-- Прогресс (только если не в архиве) -->
                                    <StackPanel Grid.Column="5" VerticalAlignment="Center"
                                                Visibility="{Binding IsArchived, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <TextBlock Text="✅ ВЫПОЛНЕНО"
                                                   HorizontalAlignment="Center"
                                                   Style="{StaticResource StatsHeaderStyle}"/>
                                        <TextBlock Text="{Binding CompletedTasksCount}"
                                                   HorizontalAlignment="Center"
                                                   Style="{StaticResource StatsValueStyle}"/>
                                    </StackPanel>

                                    <!-- Разделитель -->
                                    <Rectangle Grid.Column="6" Style="{StaticResource VerticalDividerStyle}" Margin="5 0"/>

                                    <!-- Участники -->
                                    <StackPanel Grid.Column="7" VerticalAlignment="Center">
                                        <TextBlock Text="👥 УЧАСТНИКИ"
                                                   HorizontalAlignment="Center"
                                                   Style="{StaticResource StatsHeaderStyle}"/>
                                        <TextBlock Text="{Binding MembersCount}"
                                                   HorizontalAlignment="Center"
                                                   Style="{StaticResource StatsValueStyle}"/>
                                    </StackPanel>

                                    <!-- Разделитель -->
                                    <Rectangle Grid.Column="8" Margin="5 0" Style="{StaticResource VerticalDividerStyle}"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Действия команды (только если не в архиве) -->
                        <StackPanel Orientation="Horizontal" Margin="0,20,0,0"
                                    Visibility="{Binding IsArchived, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <Button Content="👑 Передать права"
                                    Command="{Binding TransferLeadershipCommand}"
                                    Style="{StaticResource ActionButton}"
                                    Visibility="{Binding IsCaptainOrOrganizer, Converter={StaticResource BoolToVisibilityConverter}}"/>

                            <Button Content="💬 Чат команды"
                                    Command="{Binding OpenTeamChatCommand}"
                                    Style="{StaticResource ActionButton}"
                                    Margin="10,0,0,0"/>

                            <Button Content="🚪 Покинуть"
                                    Command="{Binding LeaveTeamCommand}"
                                    Style="{StaticResource ActionButton}"
                                    Margin="10,0,0,0"
                                    Visibility="{Binding IsTeamMember, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Участники и приглашения (приглашения только если не в архиве) -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,25">
                    <StackPanel>
                        <!-- Заголовок и приглашение -->
                        <DockPanel Margin="0,0,0,20">
                            <StackPanel Orientation="Horizontal" Margin="20,0,0,0"
                                        Visibility="{Binding IsCaptainOrOrganizer, Converter={StaticResource BoolToVisibilityConverter}}"
                                        DockPanel.Dock="Right">
                                <TextBlock Text="Код: " 
                                           Style="{StaticResource BodyTextStyle}"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding IsArchived, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                                <TextBox Text="{Binding InviteCode, Mode=OneWay}"
                                         Style="{StaticResource ReadingTextBox}"
                                         Width="200"
                                         VerticalAlignment="Center"
                                         IsReadOnly="True"
                                         Visibility="{Binding IsArchived, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                                <Button Content="📋" 
                                        Command="{Binding CopyInviteCodeCommand}" 
                                        Style="{StaticResource IconButton}"
                                        Margin="10,0,0,0"
                                        ToolTip="Скопировать код"
                                        Visibility="{Binding IsArchived, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                            </StackPanel>

                            <TextBlock Text="{Binding MembersSectionTitle}"
                                       Style="{StaticResource SectionHeaderStyle}"/>
                        </DockPanel>

                        <!-- Список участников -->
                        <ScrollViewer MaxHeight="250" 
                                      VerticalScrollBarVisibility="Auto"
                                      Padding="2">
                            <ItemsControl ItemsSource="{Binding Members}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource MemberCardStyle}">
                                            <Border.InputBindings>
                                                <MouseBinding Gesture="LeftClick"
                                                              Command="{Binding DataContext.ViewMemberProfileCommand,
                                                                    RelativeSource={RelativeSource AncestorType=Page}}"
                                                              CommandParameter="{Binding}"/>
                                            </Border.InputBindings>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <!-- Аватар -->
                                                    <uc:RoundAvatar Size="50" Margin="0 0 10 0"
                                                                    Source="{Binding IconPath}"
                                                                    BorderBrush="{DynamicResource BorderColor}"
                                                                    BorderThickness="3"/>

                                                    <!-- Информация -->
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Username}"
                                                                       Style="{StaticResource MemberNameStyle}"/>
                                                            <TextBlock Text=" (Вы)"
                                                                       Style="{StaticResource CurrentUserLabelStyle}"
                                                                       Visibility="{Binding IsCurrentUser, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                            <TextBlock Text=" 👑"
                                                                       Style="{StaticResource CaptainIconStyle}"
                                                                       Visibility="{Binding IsCaptain, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding PositionName, FallbackValue='Должность не указана'}"
                                                                   Style="{StaticResource MemberRoleStyle}"
                                                                   FontSize="12"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <!-- Кнопка выгнать (только для организатора, не для себя и не в архиве) -->
                                                <Button Grid.Column="1"
                                                        Content="🚪"
                                                        Command="{Binding DataContext.KickMemberCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource DangerIconButton}"
                                                        ToolTip="Выгнать из команды"
                                                        Margin="10,0,0,0"
                                                        Visibility="{Binding DataContext.IsOrganizer, 
                                                                    Converter={StaticResource BoolToVisibilityConverter},
                                                                    RelativeSource={RelativeSource AncestorType=Page}}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- Задачи команды (только если не в архиве) -->
                <Border Style="{StaticResource CardStyle}"
                        Visibility="{Binding IsArchived, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <StackPanel>
                        <!-- Заголовок и создание -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <TextBlock Text="📋 Задачи команды"
                                       Style="{StaticResource SectionHeaderStyle}"/>

                            <Button Content="＋ Новая задача"
                                    Command="{Binding CreateTaskCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="20,0,0,0"
                                    Padding="15,10"
                                    MinWidth="140"
                                    Visibility="{Binding IsCaptain, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>

                        <!-- Секции задач с прокруткой -->
                        <ScrollViewer MaxHeight="500" 
                                      VerticalScrollBarVisibility="Auto"
                                      Padding="2">
                            <ItemsControl ItemsSource="{Binding TaskSections}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,10">
                                            <!-- Заголовок секции -->
                                            <Border Style="{StaticResource TaskSectionHeaderStyle}">
                                                <Border.InputBindings>
                                                    <MouseBinding Gesture="LeftClick"
                                                                  Command="{Binding DataContext.ToggleSectionCommand, 
                                                                  RelativeSource={RelativeSource AncestorType=Page}}"
                                                                  CommandParameter="{Binding StatusId}"/>
                                                </Border.InputBindings>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Название статуса и количество -->
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding StatusName}"
                                                                   Style="{StaticResource SectionTitleStyle}"/>
                                                        <Border Style="{StaticResource CounterBadgeStyle}">
                                                            <TextBlock Text="{Binding Tasks.Count}"
                                                                       Style="{StaticResource CounterTextStyle}"/>
                                                        </Border>

                                                        <!-- Количество ваших задач -->
                                                        <Border Style="{StaticResource MyTasksBadgeStyle}" 
                                                                Visibility="{Binding HasMyTasks, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <TextBlock Text="{Binding MyTasksCount, StringFormat='ваших: {0}'}"
                                                                       Style="{StaticResource MyTasksCounterTextStyle}"/>
                                                        </Border>
                                                    </StackPanel>

                                                    <!-- Стрелка раскрытия -->
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding IsExpanded, Converter={StaticResource BoolToArrowConverter}}"
                                                               Style="{StaticResource ExpandArrowStyle}"/>
                                                </Grid>
                                            </Border>

                                            <!-- Список задач -->
                                            <ItemsControl ItemsSource="{Binding Tasks}"
                                                          Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}"
                                                          Margin="0,8,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <!-- Карточка задачи с выделением моих задач -->
                                                        <Border Style="{Binding IsMyTask, Converter={StaticResource MyTaskBorderConverter}}">
                                                            <Border.InputBindings>
                                                                <MouseBinding Gesture="LeftClick"
                                                                              Command="{Binding DataContext.OpenTaskCommand, 
                                                                                RelativeSource={RelativeSource AncestorType=Page}}"
                                                                              CommandParameter="{Binding}"/>
                                                            </Border.InputBindings>

                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>

                                                                <!-- Информация о задаче -->
                                                                <StackPanel>
                                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding Title}"
                                                                                   Style="{StaticResource TaskTitleStyle}"/>
                                                                        <!-- Индикатор моей задачи -->
                                                                        <TextBlock Text=" 👤"
                                                                                   Style="{StaticResource MyTaskIndicatorStyle}"
                                                                                   Visibility="{Binding IsMyTask, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                                    </StackPanel>

                                                                    <TextBlock Text="{Binding Description}"
                                                                               Style="{StaticResource TaskDescriptionStyle}"/>

                                                                    <!-- Мета-информация -->
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <Border Style="{StaticResource TypeBadgeStyle}">
                                                                            <TextBlock Text="{Binding TypeName}"
                                                                                       Style="{StaticResource BadgeTextStyle}"/>
                                                                        </Border>

                                                                        <TextBlock Text="👤"
                                                                                   Style="{StaticResource MetaIconStyle}"/>
                                                                        <TextBlock Text="{Binding AssignedToUsername, FallbackValue='Не назначена'}"
                                                                                   Style="{StaticResource MetaTextStyle}"/>

                                                                        <TextBlock Text="⏰"
                                                                                   Style="{StaticResource MetaIconStyle}"/>
                                                                        <TextBlock Text="{Binding Deadline, StringFormat='{}{0:dd.MM.yyyy}'}"
                                                                                   Style="{StaticResource MetaTextStyle}"/>
                                                                    </StackPanel>
                                                                </StackPanel>

                                                                <!-- Действия с задачей -->
                                                                <StackPanel Grid.Column="1"
                                                                            Orientation="Horizontal"
                                                                            Visibility="{Binding DataContext.IsCaptain, 
                                                                                 Converter={StaticResource BoolToVisibilityConverter},
                                                                                 RelativeSource={RelativeSource AncestorType=Page}}">
                                                                    <Button Content="✏️"
                                                                            Command="{Binding DataContext.EditTaskCommand, 
                                                                              RelativeSource={RelativeSource AncestorType=Page}}"
                                                                            CommandParameter="{Binding}"
                                                                            Style="{StaticResource IconButton}"
                                                                            Margin="0,0,6,0"
                                                                            ToolTip="Редактировать"/>

                                                                    <Button Content="🗑️"
                                                                            Command="{Binding DataContext.DeleteTaskCommand, 
                                                                              RelativeSource={RelativeSource AncestorType=Page}}"
                                                                            CommandParameter="{Binding}"
                                                                            Style="{StaticResource DangerIconButton}"
                                                                            ToolTip="Удалить"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- Результат команды (если есть) -->
                <Border Style="{StaticResource CardStyle}" Margin="0,15,0,0"
                        Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="🏆 Результат соревнования"
                                   Style="{StaticResource SectionHeaderStyle}"
                                   Margin="0,0,0,10"/>

                        <Border Background="{Binding PlaceBrush}" CornerRadius="12" Padding="20,15">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding PlaceDisplay}" 
                                           FontSize="28" 
                                           FontWeight="Bold" 
                                           Foreground="White"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding ResultComment, StringFormat='📝 {0}'}" 
                                           FontSize="16" 
                                           Foreground="White"
                                           TextWrapping="Wrap"
                                           HorizontalAlignment="Center"
                                           Margin="0,10,0,0"
                                           Visibility="{Binding ResultComment, Converter={StaticResource NullToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Модальное окно передачи прав -->
        <Border Style="{StaticResource ModalOverlayStyle}"
                Visibility="{Binding ShowTransferDialog, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Style="{StaticResource ModalDialogStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="👑"
                                   FontSize="20"
                                   Margin="0,0,10,0"/>
                        <TextBlock Text="Передача прав капитана"
                               Style="{StaticResource ModalTitleStyle}"/>
                    </StackPanel>

                    <TextBlock Text="Выберите нового капитана команды:"
                               Style="{StaticResource ModalDescriptionStyle}"
                               Margin="0,0,0,15"/>

                    <ComboBox ItemsSource="{Binding AvailableMembers}"
                              SelectedItem="{Binding SelectedNewCaptain}"
                              DisplayMemberPath="Username"
                              Style="{StaticResource ModernComboBox}"
                              Margin="0,0,0,20"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Отмена"
                                Command="{Binding CancelTransferCommand}"
                                Style="{StaticResource ModalSecondaryButton}"
                                Margin="0,0,10,0"/>

                        <Button Content="Передать права"
                                Command="{Binding ConfirmTransferCommand}"
                                Style="{StaticResource ModalPrimaryButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- Модальное окно создания GitHub репозитория -->
        <Border Style="{StaticResource ModalOverlayStyle}"
                Visibility="{Binding ShowCreateRepoDialog, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Style="{StaticResource ModalDialogStyle}" Width="450">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="🔗"
                                   FontSize="20"
                                   Margin="0,0,10,0"/>
                        <TextBlock Text="Создание GitHub репозитория"
                                   Style="{StaticResource ModalTitleStyle}"/>
                    </StackPanel>

                    <TextBlock Text="Создайте новый репозиторий для вашей команды"
                               Style="{StaticResource ModalDescriptionStyle}"
                               Margin="0,0,0,15"/>

                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="Название репозитория *"
                                   Style="{StaticResource StatsHeaderStyle}"
                                   Margin="0,0,0,8"/>

                        <TextBox Text="{Binding NewRepoName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Tag="my-team-project"
                                 behaviors:TextBoxGitInputBehavior.AllowOnlyGitHubRepoChars="True"/>

                        <TextBlock Text="Доступные символы: буквы (A-Z a-z), цифры (0-9), точка (.), дефис (-), нижнее подчеркивание (_)"
                                   Style="{StaticResource CaptionSecondaryStyle}"
                                   Margin="0,5,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="Описание"
                                   Style="{StaticResource StatsHeaderStyle}"
                                   Margin="0,0,0,8"/>
                        <TextBox Text="{Binding NewRepoDescription, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Height="60"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Tag="Описание проекта команды..."/>
                    </StackPanel>

                    <Border Style="{StaticResource StatsContainerStyle}" Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <CheckBox IsChecked="{Binding NewRepoIsPrivate}"
                                      Content="Приватный репозиторий"
                                      Style="{StaticResource ModernCheckBox}"
                                      FontWeight="SemiBold"
                                      VerticalAlignment="Center"/>
                            <TextBlock Text="🔒"
                                       Style="{StaticResource BodyLargeStyle}"
                                       Margin="10,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StatsContainerStyle}" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="ℹ️ Информация:"
                                       Style="{StaticResource BodyTextStyle}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,5"/>
                            <TextBlock Text="Репозиторий будет создан в аккаунте капитана команды"
                                       Style="{StaticResource CaptionSecondaryStyle}"/>
                            <TextBlock Text="Будут автоматически созданы: README, issues, projects, wiki"
                                       Style="{StaticResource CaptionSecondaryStyle}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Отмена"
                                Command="{Binding CancelCreateRepoCommand}"
                                Style="{StaticResource ModalSecondaryButton}"
                                Margin="0,0,10,0"/>

                        <Button Content="Создать репозиторий"
                                Command="{Binding CreateGitHubRepoCommand}"
                                Style="{StaticResource ModalPrimaryButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Page>