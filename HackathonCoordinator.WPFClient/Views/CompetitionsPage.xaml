<Page x:Class="HackathonCoordinator.WPFClient.Views.CompetitionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:HackathonCoordinator.WPFClient.ViewModels"
      Title="Соревнования"
      Unloaded="Page_Unloaded">

    <Page.DataContext>
        <vm:CompetitionsViewModel/>
    </Page.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок и управление -->
        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="🏆 Соревнования" 
                               FontSize="28" 
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextColor}"/>
                    <TextBlock Text="Выберите соревнование для участия или управления"
                               Style="{StaticResource BodyTextStyle}"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <Button Content="＋ Создать соревнование"
                        Command="{Binding AddCompetitionCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Margin="30,0,0,0"
                        Height="45"
                        Visibility="{Binding IsOrganizer, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StackPanel>
        </Border>

        <!-- Фильтрация -->
        <Border Style="{StaticResource CardStyle}" Grid.Row="1" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Фильтр по статусу:"
                           Style="{StaticResource BodyTextStyle}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>

                <ComboBox ItemsSource="{Binding StatusFilters}"
                          SelectedItem="{Binding SelectedStatusFilter}"
                          DisplayMemberPath="Name"
                          Style="{StaticResource ModernComboBox}"
                          Width="200"
                          VerticalAlignment="Center"/>

                <TextBlock Text="{Binding FilteredCompetitionsCount, StringFormat='Показано: {0} соревнований'}"
                           Style="{StaticResource BodyTextStyle}"
                           VerticalAlignment="Center"
                           Margin="15,0,0,0"
                           Foreground="{DynamicResource TextSecondaryColor}"/>
            </StackPanel>
        </Border>

        <!-- Список соревнований -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <ItemsControl ItemsSource="{Binding FilteredCompetitions}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="{Binding RelativeSource={RelativeSource AncestorType=Page}, Path=ActualWidth, Converter={StaticResource WidthToColumnsConverter}}"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource InteractiveCardStyle}" 
                                    Margin="0,0,0,20">
                                <Border.InputBindings>
                                    <MouseBinding Gesture="LeftClick"
                                                  Command="{Binding DataContext.SelectCompetitionCommand, 
                                                                    RelativeSource={RelativeSource AncestorType=Page}}"
                                                  CommandParameter="{Binding}" />
                                </Border.InputBindings>
                                <StackPanel Margin="0,0,4,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Иконка статуса -->
                                        <Border Width="60" 
                                                Height="60" 
                                                CornerRadius="12"
                                                Background="{Binding StatusColor, Converter={StaticResource CompetitionStatusToBrushConverter}}"
                                                VerticalAlignment="Top">
                                            <TextBlock Text="{Binding StatusIcon}"
                                                       FontSize="24"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Основная информация -->
                                        <StackPanel Grid.Column="1" Margin="20 0 0 0">
                                            <DockPanel Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Name}" 
                                                           FontSize="24" 
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource TextColor}"
                                                           VerticalAlignment="Top"/>

                                                <Border Background="{Binding StatusColor, Converter={StaticResource CompetitionStatusToBrushConverter}}"
                                                        CornerRadius="10"
                                                        Padding="8,3"
                                                        Margin="15,0,0,0"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding StatusText}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="White"/>
                                                </Border>
                                                <!-- Кнопки управления -->
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                                            VerticalAlignment="Center"
                                                            Visibility="{Binding DataContext.IsOrganizer, 
                                                                                Converter={StaticResource BoolToVisibilityConverter},
                                                                                RelativeSource={RelativeSource AncestorType=Page}}">
                                                                                                <Button Content="✏️"
                                                            Command="{Binding DataContext.EditCompetitionCommand, 
                                                                             RelativeSource={RelativeSource AncestorType=Page}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource RoundIconButton}"
                                                            Margin="0,0,4,0"
                                                            ToolTip="Редактировать"
                                                            Width="40" Height="40"/>

                                                    <Button Content="👁️"
                                                            Command="{Binding DataContext.SelectCompetitionCommand, 
                                                                             RelativeSource={RelativeSource AncestorType=Page}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource RoundIconButton}"
                                                            Margin="0,0,4,0"
                                                            ToolTip="Просмотр"
                                                            Width="40" Height="40"/>

                                                    <Button Content="📤"
                                                            Command="{Binding DataContext.ExportCompetitionCommand, 
                                                                             RelativeSource={RelativeSource AncestorType=Page}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource RoundIconButton}"
                                                            ToolTip="Экспортировать данные соревнования и данные всех команд"
                                                            Margin="0,0,4,0"
                                                            Width="40" Height="40"
                                                            Background="{DynamicResource SuccessBrush}"/>

                                                    <Button Content="📦"
                                                            Command="{Binding DataContext.ArchiveCompetitionCommand,
                                                                              RelativeSource={RelativeSource AncestorType=Page}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource DangerIconButton}"
                                                            ToolTip="Архивировать соревнование"
                                                            Width="40" Height="40"
                                                            Margin="0,0,4,0"
                                                            Visibility="{Binding IsArchived, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                                                    <Button Content="🗑️"
                                                            Command="{Binding DataContext.DeleteCompetitionCommand,
                                                                              RelativeSource={RelativeSource AncestorType=Page}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource DangerIconButton}"
                                                            Width="40" Height="40"
                                                            ToolTip="Удалить соревнование и все связанные данные"/>
                                                </StackPanel>
                                            </DockPanel>

                                            <TextBlock Text="{Binding Description}"
                                                       Style="{StaticResource BodyTextStyle}"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="40"
                                                       Margin="0,0,0,12"/>
                                        </StackPanel>
                                    </Grid>
                                    <Border Background="{DynamicResource ControlBackground}"
                                            CornerRadius="8"
                                            Padding="12"
                                            BorderBrush="{DynamicResource BorderColor}"
                                            BorderThickness="1">
                                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                                    <TextBlock Text="📅"
                                                           FontSize="14"
                                                           Margin="0,0,8,0"/>
                                                                                    <TextBlock Text="{Binding DateTimeRangeText}"
                                                           Style="{StaticResource BodyTextStyle}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Сообщение когда нет соревнований -->
                <TextBlock Text="🎯 Нет доступных соревнований"
                           Style="{StaticResource BodyTextStyle}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="0,50,0,0"
                           FontSize="16"
                           Visibility="{Binding HasNoCompetitions, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <!-- Сообщение когда нет соревнований после фильтрации -->
                <Border Style="{StaticResource CardStyle}"
                        Margin="0,20,0,0"
                        Visibility="{Binding HasNoFilteredCompetitions, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="🔍"
                                   FontSize="24"
                                   Margin="0,0,15,0"/>
                        <StackPanel>
                            <TextBlock Text="Соревнования не найдены"
                                       Style="{StaticResource BodyTextStyle}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Попробуйте изменить фильтр или создать новое соревнование"
                                       Style="{StaticResource BodyTextStyle}"
                                       Foreground="{DynamicResource TextSecondaryColor}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>