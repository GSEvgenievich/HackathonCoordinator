<Page x:Class="HackathonCoordinator.WPFClient.Views.CompetitionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:HackathonCoordinator.WPFClient.ViewModels"
      xmlns:converters="clr-namespace:HackathonCoordinator.WPFClient.Converters"
      Title="Соревнования">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Page.DataContext>
        <vm:CompetitionsViewModel/>
    </Page.DataContext>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок и кнопка добавления -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,20">
            <TextBlock Text="Соревнования" 
                       FontSize="26" 
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextColor}"/>

            <Button Content="＋ Добавить соревнование"
                    Command="{Binding AddCompetitionCommand}"
                    Style="{StaticResource PrimaryButton}"
                    Margin="20,0,0,0"
                    Visibility="{Binding IsOrganizer, Converter={StaticResource BoolToVisibilityConverter}}"/>
        </StackPanel>

        <!-- Список соревнований -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Competitions}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource InteractiveCardStyle}" 
                                Margin="0,0,0,15">
                            <Border.InputBindings>
                                <MouseBinding Gesture="LeftClick"
                                              Command="{Binding DataContext.SelectCompetitionCommand, 
                                                                RelativeSource={RelativeSource AncestorType=Page}}"
                                              CommandParameter="{Binding}" />
                            </Border.InputBindings>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Информация о соревновании -->
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" 
                                               FontSize="18" 
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextColor}"
                                               Margin="0,0,0,5"/>

                                    <TextBlock Text="{Binding Description}"
                                               Style="{StaticResource BodyTextStyle}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,10"/>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding StartDate, StringFormat='Начало: {0:dd.MM.yyyy HH:mm}'}"
                                                   Style="{StaticResource BodyTextStyle}"
                                                   Margin="0,0,15,0"/>
                                        <TextBlock Text="{Binding EndDate, StringFormat='Окончание: {0:dd.MM.yyyy HH:mm}'}"
                                                   Style="{StaticResource BodyTextStyle}"/>
                                    </StackPanel>

                                    <TextBlock Text="{Binding Teams.Count, StringFormat='Команд: {0}'}"
                                               Style="{StaticResource BodyTextStyle}"
                                               Margin="0,5,0,0"/>
                                </StackPanel>

                                <!-- Кнопки управления для организатора -->
                                <StackPanel Grid.Column="1" 
                                            Orientation="Horizontal"
                                            Visibility="{Binding DataContext.IsOrganizer, 
                                                                Converter={StaticResource BoolToVisibilityConverter},
                                                                RelativeSource={RelativeSource AncestorType=Page}}">
                                    <Button Content="✏️"
                                            Command="{Binding DataContext.EditCompetitionCommand, 
                                                             RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource RoundIconButton}"
                                            Margin="0,0,5,0"
                                            ToolTip="Редактировать"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>