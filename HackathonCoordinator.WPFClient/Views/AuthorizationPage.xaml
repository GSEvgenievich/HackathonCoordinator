<Page x:Class="HackathonCoordinator.WPFClient.Views.AuthorizationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:vm="clr-namespace:HackathonCoordinator.WPFClient.ViewModels"
      xmlns:local="clr-namespace:HackathonCoordinator.WPFClient.Views"
      mc:Ignorable="d" 
      Title="AuthorizationPage"
      Background="White">

    <Page.DataContext>
        <vm:AuthorizationViewModel/>
    </Page.DataContext>

    <Grid>
        <Border Background="#F5F5F5" 
                BorderBrush="#DDDDDD" 
                BorderThickness="1" 
                CornerRadius="10"
                Width="350" 
                Height="400"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <StackPanel Margin="30" VerticalAlignment="Center">
                <TextBlock Text="Авторизация" 
                          FontSize="24" 
                          FontWeight="Bold" 
                          HorizontalAlignment="Center" 
                          Margin="0,0,0,30"
                          Foreground="#333333"/>

                <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                         Tag="Логин"
                         Style="{StaticResource ModernTextBox}"
                         Margin="0,0,0,20"/>

                <PasswordBox x:Name="PasswordBox"
                             Tag="Пароль"
                             Style="{StaticResource ModernPasswordBox}"
                             Margin="0,0,0,30"/>

                <Button Content="Войти" 
                        Command="{Binding LoginCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Height="40"
                        Margin="0,0,0,20"/>

                <TextBlock Text="Нет аккаунта?" 
                          HorizontalAlignment="Center" 
                          Foreground="#666666"
                          Margin="0,0,0,10"/>

                <Button Content="Зарегистрироваться" 
                        Command="{Binding NavigateToRegistrationCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Height="35"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
