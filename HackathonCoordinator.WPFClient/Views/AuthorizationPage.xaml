<Page x:Class="HackathonCoordinator.WPFClient.Views.AuthorizationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:vm="clr-namespace:HackathonCoordinator.WPFClient.ViewModels"
      xmlns:converters="clr-namespace:HackathonCoordinator.WPFClient.Converters"
      mc:Ignorable="d" 
      Title="Авторизация">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Page.DataContext>
        <vm:AuthorizationViewModel/>
    </Page.DataContext>

    <Grid>
        <!-- Фоновое изображение темы -->
        <Grid.Background>
            <DynamicResource ResourceKey="MainBackgroundBrush"/>
        </Grid.Background>

        <Border Style="{StaticResource CardStyle}"
                Width="400"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Padding="0">

            <!-- Внутренний контейнер с градиентом -->
            <Border Background="{DynamicResource AccentBackgroundBrush}"
                    CornerRadius="12"
                    Margin="1">

                <StackPanel Margin="40" VerticalAlignment="Center">

                    <!-- Заголовок с иконкой -->
                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Center" 
                                Margin="0,0,0,30">
                        <TextBlock Text="🔐" 
                                   FontSize="28"
                                   Foreground="{DynamicResource TextColor}"
                                   Margin="0,0,10,0"/>
                        <TextBlock Text="Авторизация" 
                                   Style="{StaticResource PageTitleStyle}"/>
                    </StackPanel>

                    <!-- Поле логина -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Логин"
                                   Style="{StaticResource BodyTextStyle}"
                                   Foreground="{DynamicResource SidebarTextColor}"
                                   FontSize="14"
                                   Margin="0,0,0,8"/>
                        <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="Введите логин:"
                                 Style="{StaticResource ModernTextBox}"
                                 Foreground="{DynamicResource TextColor}"/>
                    </StackPanel>

                    <!-- Поле пароля -->
                    <StackPanel Margin="0,0,0,30">
                        <TextBlock Text="Пароль"
                                   Style="{StaticResource BodyTextStyle}"
                                   Foreground="{DynamicResource SidebarTextColor}"
                                   FontSize="14"
                                   Margin="0,0,0,8"/>
                        <PasswordBox x:Name="PasswordBox"
                                     Tag="Введите пароль:"
                                     Style="{StaticResource ModernPasswordBox}"
                                     Foreground="{DynamicResource TextColor}"/>
                    </StackPanel>

                    <Border Style="{StaticResource CardStyle}"
                            Background="{DynamicResource ControlBackground}">
                        <StackPanel>
                            <Button Content="Войти" 
                                    Command="{Binding LoginCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Height="50"
                                    FontSize="16"
                                    Margin="0,0,0,20"/>

                            <StackPanel Orientation="Horizontal" 
                                        HorizontalAlignment="Center">
                                <TextBlock Text="Нет аккаунта?" 
                                           Style="{StaticResource BodyTextStyle}"
                                           VerticalAlignment="Center"/>
                                <Button Content="Создать" 
                                        Command="{Binding NavigateToRegistrationCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="10,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Page>