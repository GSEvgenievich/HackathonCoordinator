<Page x:Class="HackathonCoordinator.WPFClient.Views.NoTeamPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:HackathonCoordinator.WPFClient.ViewModels"
      Background="{DynamicResource BackgroundColor}">

    <Page.DataContext>
        <vm:NoTeamViewModel/>
    </Page.DataContext>

    <Grid>
        <Border Style="{StaticResource CardStyle}"
                Padding="40"
                Width="600"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="У вас пока нет команды"
                           Style="{StaticResource PageTitleStyle}"/>

                <TextBlock Text="Выберите, хотите ли вы создать новую команду или присоединиться к существующей."
                           Style="{StaticResource BodyTextStyle}"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <!-- Левая часть — Создание команды -->
                    <StackPanel Width="220" Margin="0,0,40,0">
                        <Button Content="Создать команду"
                                Command="{Binding CreateTeamCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Height="60"
                                Margin="0,0,0,15"/>

                        <TextBlock Text="Название новой команды:"
                                   Style="{StaticResource BodyTextStyle}"
                                   Margin="0,0,0,5"/>

                        <TextBox Text="{Binding TeamName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>

                    <!-- Правая часть — Присоединение к команде -->
                    <StackPanel Width="220">
                        <Button Content="Присоединиться"
                                Command="{Binding JoinTeamCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Height="60"
                                Margin="0,0,0,15"/>

                        <TextBlock Text="Код приглашения:"
                                   Style="{StaticResource BodyTextStyle}"
                                   Margin="0,0,0,5"/>

                        <TextBox Text="{Binding InviteCode, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>