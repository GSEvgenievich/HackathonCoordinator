<Page x:Class="HackathonCoordinator.WPFClient.Views.NoTeamPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:HackathonCoordinator.WPFClient.ViewModels"
      xmlns:converters="clr-namespace:HackathonCoordinator.WPFClient.Converters">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Page.DataContext>
        <vm:NoTeamViewModel/>
    </Page.DataContext>

    <Grid>
        <Border Style="{StaticResource CardStyle}"
                Padding="40"
                Width="600"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="У вас пока нет команды"
                           Style="{StaticResource PageTitleStyle}"/>

                <TextBlock Text="Выберите, хотите ли вы создать новую команду или присоединиться к существующей."
                           Style="{StaticResource BodyTextStyle}"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <!-- Левая часть — Создание команды -->
                    <StackPanel Width="220" Margin="0,0,40,0">
                        <Button Content="Создать команду"
                                Command="{Binding CreateTeamCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Height="60"
                                Margin="0,0,0,15"/>

                        <TextBlock Text="Название новой команды:"
                                   Style="{StaticResource BodyTextStyle}"
                                   Margin="0,0,0,5"/>

                        <TextBox Text="{Binding TeamName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Margin="0,0,0,10"/>

                        <!-- Чекбокс привязки к GitHub -->
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <CheckBox IsChecked="{Binding LinkToGitHub}"
                                      IsEnabled="{Binding HasGitHubAccount}"
                                      VerticalAlignment="Center"/>

                            <TextBlock Text="Привязать к GitHub"
                                       Style="{StaticResource BodyTextStyle}"
                                       VerticalAlignment="Center"
                                       Margin="5,0,0,0"/>

                            <!-- Значок вопросика с подсказкой -->
                            <Button Content="?"
                                    Style="{StaticResource RoundIconButton}"
                                    ToolTipService.ShowDuration="30000"
                                    VerticalAlignment="Center"
                                    Margin="5,0,0,0">
                                <Button.ToolTip>
                                    <ToolTip>
                                        <StackPanel MaxWidth="300">
                                            <TextBlock Text="GitHub интеграция для команды"
                                                       FontWeight="Bold"
                                                       Margin="0,0,0,5"/>
                                            <TextBlock Text="При создании команды будет привязан GitHub профиль лидера. Все проекты команды будут создаваться в аккаунте лидера."
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="Преимущества:"
                                                       FontWeight="SemiBold"
                                                       Margin="0,8,0,2"/>
                                            <TextBlock Text="• Автоматическое создание репозиториев для проектов"
                                                       FontSize="11"/>
                                            <TextBlock Text="• Создание issues и веток для задач"
                                                       FontSize="11"/>
                                            <TextBlock Text="• Интеграция с GitHub Projects"
                                                       FontSize="11"/>
                                            <TextBlock Text="Требуется привязанный GitHub аккаунт."
                                                       FontStyle="Italic"
                                                       Margin="0,5,0,0"
                                                       Foreground="Orange"/>
                                        </StackPanel>
                                    </ToolTip>
                                </Button.ToolTip>
                            </Button>
                        </StackPanel>

                        <!-- Сообщение если GitHub не привязан -->
                        <TextBlock Text="Привяжите GitHub аккаунт в профиле"
                                   Style="{StaticResource BodyTextStyle}"
                                   Foreground="OrangeRed"
                                   FontSize="11"
                                   Margin="0,5,0,0"
                                   Visibility="{Binding ShowGitHubWarning, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>

                    <!-- Правая часть — Присоединение к команде -->
                    <StackPanel Width="220">
                        <Button Content="Присоединиться"
                                Command="{Binding JoinTeamCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Height="60"
                                Margin="0,0,0,15"/>

                        <TextBlock Text="Код приглашения:"
                                   Style="{StaticResource BodyTextStyle}"
                                   Margin="0,0,0,5"/>

                        <TextBox Text="{Binding InviteCode, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>