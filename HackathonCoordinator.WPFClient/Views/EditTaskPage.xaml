<Page x:Class="HackathonCoordinator.WPFClient.Views.EditTaskPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:HackathonCoordinator.WPFClient.ViewModels"
      Title="Задача">

    <Page.DataContext>
        <vm:EditTaskViewModel/>
    </Page.DataContext>

    <Grid Margin="30">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Width="600" HorizontalAlignment="Left">

                <!-- Заголовок -->
                <TextBlock Text="{Binding PageTitle}" 
                           FontSize="26" 
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextColor}"
                           Margin="0,0,0,20"/>

                <!-- Форма редактирования -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <!-- Название задачи -->
                        <TextBlock Text="Название задачи *"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextColor}"
                                   Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Margin="0,0,0,15"/>

                        <!-- Описание -->
                        <TextBlock Text="Описание задачи"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextColor}"
                                   Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Height="120"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,15"/>

                        <!-- Тип задачи и исполнитель -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Тип задачи -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Тип задачи *"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextColor}"
                                           Margin="0,0,0,5"/>
                                <ComboBox ItemsSource="{Binding TaskTypes}"
                                          SelectedItem="{Binding SelectedType}"
                                          DisplayMemberPath="Name"
                                          Style="{StaticResource ModernComboBox}"/>
                            </StackPanel>

                            <!-- Пустой разделитель -->
                            <Rectangle Grid.Column="1" Fill="Transparent"/>

                            <!-- Исполнитель -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Исполнитель"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextColor}"
                                           Margin="0,0,0,5"/>
                                <ComboBox ItemsSource="{Binding AvailableAssignees}"
                                          SelectedItem="{Binding SelectedAssignee}"
                                          DisplayMemberPath="Username"
                                          Style="{StaticResource ModernComboBox}"/>
                                <TextBlock Text="{Binding AvailableAssignees.Count, StringFormat='Доступно исполнителей: {0}'}"
                                           Style="{StaticResource BodyTextStyle}"
                                           FontSize="12"
                                           Margin="0,5,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- Дедлайн и ветка GitHub -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Дедлайн -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Дедлайн"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextColor}"
                                           Margin="0,0,0,5"/>
                                <DatePicker SelectedDate="{Binding Deadline}"
                                            Style="{StaticResource ModernDatePicker}"/>
                            </StackPanel>

                            <!-- Пустой разделитель -->
                            <Rectangle Grid.Column="1" Fill="Transparent"/>

                            <!-- GitHub ветка -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="GitHub ветка"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextColor}"
                                           Margin="0,0,0,5"/>
                                <TextBox Text="{Binding GithubBranchName, UpdateSourceTrigger=PropertyChanged}"
                                         Tag="{Binding GithubBranchHint}"
                                         Style="{StaticResource ModernTextBox}"/>
                                <TextBlock Text="{Binding GithubBranchHint, StringFormat='Рекомендуемый формат: {0}название-ветки'}"
                                           Style="{StaticResource BodyTextStyle}"
                                           FontSize="12"
                                           Margin="0,5,0,0"/>
                                <TextBlock Text="Подсказка меняется автоматически при выборе типа задачи"
                                           Style="{StaticResource BodyTextStyle}"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryColor}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- Кнопки действий -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Отмена"
                                    Command="{Binding CancelCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="0,0,10,0"/>

                            <Button Content="{Binding SaveButtonText}"
                                    Command="{Binding SaveCommand}"
                                    Style="{StaticResource PrimaryButton}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Сообщения об ошибках -->
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource DangerBrush}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Margin="0,10,0,0"
                           Visibility="{Binding HasErrorMessage, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>