<Page x:Class="HackathonCoordinator.WPFClient.Views.EditTaskPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:HackathonCoordinator.WPFClient.ViewModels"
      Title="Задача"
      Unloaded="Page_Unloaded">

    <Page.DataContext>
        <vm:EditTaskViewModel/>
    </Page.DataContext>

    <Grid Margin="30">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Заголовок страницы -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="← Назад к проекту" 
                                Command="{Binding CancelCommand}"
                                Style="{StaticResource NavigationButton}"
                                Margin="0,0,20,0"/>

                        <StackPanel>
                            <TextBlock Text="{Binding PageTitle}" 
                                   Style="{StaticResource PageHeaderStyle}"/>
                            <TextBlock Text="{Binding PageSubtitle}"
                                   Style="{StaticResource PageSubtitleStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Форма редактирования -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>

                        <!-- Название задачи -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="📝 Название задачи"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Margin="0,0,0,8"/>
                            <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Tag="Введите название задачи:"/>
                            <TextBlock Text="* Обязательное поле"
                                   Style="{StaticResource CaptionSecondaryStyle}"
                                   Margin="0,5,0,0"/>
                        </StackPanel>

                        <!-- Описание -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="📄 Описание задачи"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Margin="0,0,0,8"/>
                            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Height="100"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Tag="Опишите задачу подробно:"/>
                        </StackPanel>

                        <!-- Тип задачи и исполнитель -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="🎯 Параметры задачи"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Margin="0,0,0,8"/>

                            <Border Style="{StaticResource StatsContainerStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Тип задачи -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Тип задачи *"
                                               Style="{StaticResource StatsHeaderStyle}"
                                               Margin="0,0,0,8"/>
                                        <ComboBox ItemsSource="{Binding TaskTypes}"
                                              SelectedItem="{Binding SelectedType}"
                                              DisplayMemberPath="Name"
                                              Style="{StaticResource ModernComboBox}"/>
                                    </StackPanel>

                                    <!-- Разделитель -->
                                    <Rectangle Grid.Column="1" Style="{StaticResource VerticalDividerStyle}"/>

                                    <!-- Исполнитель -->
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Исполнитель"
                                               Style="{StaticResource StatsHeaderStyle}"
                                               Margin="0,0,0,8"/>
                                        <ComboBox ItemsSource="{Binding TeamMembers}"
                                              SelectedItem="{Binding SelectedAssignee}"
                                              DisplayMemberPath="Username"
                                              Style="{StaticResource ModernComboBox}"/>
                                        <TextBlock Text="{Binding TeamMembers.Count, StringFormat='Доступно исполнителей: {0}'}"
                                               Style="{StaticResource CaptionSecondaryStyle}"
                                               Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Дедлайн и ветка GitHub -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="⏰ Дополнительные параметры"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Margin="0,0,0,8"/>

                            <Border Style="{StaticResource StatsContainerStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Дедлайн -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="📅 Дедлайн"
                                               Style="{StaticResource StatsHeaderStyle}"
                                               Margin="0,0,0,8"/>
                                        <DatePicker SelectedDate="{Binding Deadline}"
                                                Style="{StaticResource ModernDatePicker}"/>
                                    </StackPanel>

                                    <!-- Разделитель -->
                                    <Rectangle Grid.Column="1" Style="{StaticResource VerticalDividerStyle}"/>

                                    <!-- GitHub ветка -->
                                    <StackPanel Grid.Column="2"
                                                Visibility="{Binding ShowGitHubSection, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="🔗 GitHub ветка"
                                                   Style="{StaticResource StatsHeaderStyle}"
                                                   Margin="0,0,0,8"/>

                                        <!-- Режим просмотра для существующей ветки -->
                                        <TextBox Text="{Binding GitHubBranchName, UpdateSourceTrigger=PropertyChanged}"
                                                 Tag="{Binding GithubBranchHint}"
                                                 Style="{StaticResource ModernTextBox}"
                                                 IsReadOnly="{Binding IsBranchReadOnly}"
                                                 ToolTip="{Binding BranchToolTip}"/>

                                        <!-- Подсказки -->
                                        <StackPanel>
                                            <TextBlock Text="{Binding GithubBranchHint, StringFormat='Рекомендуемый формат: {0}название-ветки'}"
                                                        Style="{StaticResource CaptionSecondaryStyle}"
                                                        Margin="0,5,0,0"/>

                                            <!-- Сообщение о существующей ветке -->
                                            <TextBlock Text="⚠️ Ветка уже создана в GitHub. Изменить нельзя."
                                                        Style="{StaticResource CaptionSecondaryStyle}"
                                                        Foreground="Orange"
                                                        Margin="0,5,0,0"
                                                        Visibility="{Binding ShowBranchWarning, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                            <!-- Сообщение о создании новой ветки -->
                                            <TextBlock Text="ℹ️ Будет создана новая ветка в GitHub репозитории команды"
                                                   Style="{StaticResource CaptionSecondaryStyle}"
                                                   Foreground="{DynamicResource PrimaryBrush}"
                                                   Margin="0,5,0,0"
                                                   Visibility="{Binding ShowBranchInfo, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Кнопки действий -->
                        <Border Style="{StaticResource StatsContainerStyle}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Отмена"
                                    Command="{Binding CancelCommand}"
                                    Style="{StaticResource ModalSecondaryButton}"
                                    Margin="0,0,12,0"/>

                                <Button Content="{Binding SaveButtonText}"
                                    Command="{Binding SaveCommand}"
                                    Style="{StaticResource ModalPrimaryButton}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Сообщения об ошибках -->
                <Border Style="{StaticResource StatsContainerStyle}"
                        Background="{DynamicResource DangerBrush}"
                        Visibility="{Binding HasErrorMessage, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠️"
                               Style="{StaticResource BodyLargeStyle}"
                               Foreground="White"
                               Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                               Style="{StaticResource BodyTextStyle}"
                               Foreground="White"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>