<Window x:Class="HackathonCoordinator.WPFClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:HackathonCoordinator.WPFClient.ViewModels"
        mc:Ignorable="d"
        Icon="/Assets/Images/Icon.ico"
        Title="Hackathon Coordinator"
        Height="600"
        Width="1000"
        MinHeight="680"
        MinWidth="900"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>

    <Grid>
        <!-- Основной фон с изображением активной темы -->
        <Grid.Background>
            <DynamicResource ResourceKey="MainBackgroundBrush" />
        </Grid.Background>

        <!-- Основной контент -->
        <Frame x:Name="MainFrame"
               NavigationUIVisibility="Hidden"
               Margin="60 0 0 0"
               Background="Transparent" />

        <!-- Боковая панель навигации -->
        <Border x:Name="SideBar"
                Background="{DynamicResource AccentBackgroundBrush}"
                Width="60"
                CornerRadius="0 12 0 0"
                VerticalAlignment="Stretch"
                HorizontalAlignment="Left"
                MouseEnter="SideBar_MouseEnter"
                MouseLeave="SideBar_MouseLeave"
                Panel.ZIndex="1000">

            <Border.Effect>
                <DropShadowEffect BlurRadius="10"
                                  ShadowDepth="2"
                                  Opacity="0.3"
                                  Direction="0" />
            </Border.Effect>

            <StackPanel>
                <!-- Профиль пользователя -->
                <Button Command="{Binding OpenProfileCommand}"
                        Style="{StaticResource SidebarButtonStyle}"
                        Tag="ProfilePage"
                        ToolTip="Профиль">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Left">
                        <TextBlock Text="👤"
                                   FontSize="18"
                                   Margin="10,0,0,0" />
                        <TextBlock x:Name="ProfileText"
                                   Text="{Binding Username}"
                                   Margin="10,0,0,0"
                                   Visibility="Collapsed"
                                   Foreground="{DynamicResource SidebarTextColor}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Separator Margin="5"
                           Background="{DynamicResource BorderColor}" />

                <!-- Кнопки навигации -->
                <Button Command="{Binding OpenMainPageCommand}"
                        Style="{StaticResource SidebarButtonStyle}"
                        Tag="MainPage"
                        ToolTip="Главная">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Left">
                        <TextBlock Text="🏠"
                                   FontSize="18"
                                   Margin="10,0,0,0" />
                        <TextBlock x:Name="MainText"
                                   Text="Главная"
                                   Margin="10,0,0,0"
                                   Visibility="Collapsed"
                                   Foreground="{DynamicResource SidebarTextColor}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Command="{Binding OpenUsersManagementCommand}"
                        Style="{StaticResource SidebarButtonStyle}"
                        Tag="UsersManagementPage"
                        ToolTip="Управление участниками"
                        Visibility="{Binding IsOrganizer, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Left">
                        <TextBlock Text="👥"
                                   FontSize="18"
                                   Margin="10,0,0,0" />
                        <TextBlock x:Name="UsersManagementText"
                                   Text="Участники"
                                   Margin="10,0,0,0"
                                   Visibility="Collapsed"
                                   Foreground="{DynamicResource SidebarTextColor}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource SidebarButtonStyle}"
                        Command="{Binding OpenNotificationsCommand}"
                        Tag="NotificationsPage"
                        ToolTip="Уведомления">
                    <Grid>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Left">
                            <TextBlock Text="🔔"
                                       FontSize="18"
                                       Margin="10,0,0,0" />
                            <TextBlock x:Name="NotificationsText"
                                       Text="Уведомления"
                                       Margin="10,0,0,0"
                                       Visibility="Collapsed"
                                       Foreground="{DynamicResource SidebarTextColor}"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Бейдж с количеством -->
                        <Border x:Name="NotificationBadge"
                                Background="{DynamicResource DangerBrush}"
                                BorderBrush="White"
                                BorderThickness="2"
                                CornerRadius="10"
                                Width="20"
                                Height="20"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="20,-5,0,0"
                                Visibility="{Binding HasUnreadNotifications, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="{Binding UnreadNotificationsCount}"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center" />
                        </Border>
                    </Grid>
                </Button>

                <Button Command="{Binding OpenChatsCommand}"
                        Style="{StaticResource SidebarButtonStyle}"
                        Tag="ChatsPage"
                        ToolTip="Чаты">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Left">
                        <TextBlock Text="💬"
                                   FontSize="18"
                                   Margin="10,0,0,0" />
                        <TextBlock x:Name="ChatsText"
                                   Text="Чаты"
                                   Margin="10,0,0,0"
                                   Visibility="Collapsed"
                                   Foreground="{DynamicResource SidebarTextColor}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Separator Margin="5"
                           Background="{DynamicResource BorderColor}" />

                <!-- Управление темами -->
                <Button Style="{StaticResource SidebarButtonStyle}"
                        Command="{Binding ToggleThemeCommand}"
                        ToolTip="Сменить тему">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Left">
                        <TextBlock Text="🎨"
                                   FontSize="18"
                                   Margin="10,0,0,0" />
                        <TextBlock x:Name="ThemeText"
                                   Text="Тема"
                                   Margin="10,0,0,0"
                                   Visibility="Collapsed"
                                   Foreground="{DynamicResource SidebarTextColor}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Индикатор текущей темы -->
                <Border Background="{DynamicResource CardBackground}"
                        CornerRadius="5"
                        Margin="5,2,5,2"
                        Padding="2"
                        Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="{Binding CurrentThemeName}"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <!-- Кнопка выхода -->
                <Button Style="{StaticResource SidebarButtonStyle}"
                        Command="{Binding LogoutCommand}"
                        ToolTip="Выйти">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Left">
                        <TextBlock Text="🚪"
                                   FontSize="18"
                                   Margin="10,0,0,0" />
                        <TextBlock x:Name="LogoutText"
                                   Text="Выйти"
                                   Margin="10,0,0,0"
                                   Visibility="Collapsed"
                                   Foreground="{DynamicResource SidebarTextColor}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>