<Window x:Class="HackathonCoordinator.WPFClient.UserControls.InputDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ввод данных"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        MinWidth="350"
        MaxWidth="450">

    <Border Background="{DynamicResource CardBackground}"
            CornerRadius="16"
            BorderBrush="{DynamicResource BorderColor}"
            BorderThickness="1"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="5" Opacity="0.3"/>
        </Border.Effect>

        <StackPanel Margin="25">
            <!-- Заголовок -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <TextBlock Text="✏️" FontSize="24" Margin="0,0,12,0"/>
                <TextBlock x:Name="TitleText" Text="Создание команды" Style="{StaticResource H4Style}" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Поле ввода -->
            <TextBlock x:Name="PromptText" Text="Введите название команды:" 
                       Style="{StaticResource BodyTextStyle}"
                       Margin="0,0,0,8"/>

            <TextBox x:Name="InputTextBox" 
                     Style="{StaticResource ModernTextBox}"
                     MinHeight="35"
                     Margin="0,0,0,20"
                     Tag="Название команды..."
                     KeyDown="InputTextBox_KeyDown"/>

            <!-- Кнопки -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButton" 
                        Content="Отмена" 
                        Style="{StaticResource ModalSecondaryButton}"
                        Width="80"
                        Margin="0,0,10,0"
                        Click="CancelButton_Click"/>
                <Button x:Name="OkButton" 
                        Content="Создать" 
                        Style="{StaticResource ModalPrimaryButton}"
                        Width="80"
                        Click="OkButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>