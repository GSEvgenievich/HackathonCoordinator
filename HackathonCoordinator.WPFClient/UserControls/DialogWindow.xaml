<Window x:Class="HackathonCoordinator.WPFClient.UserControls.DialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Диалог"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        MinWidth="350"
        MaxWidth="500">

    <Border Background="{DynamicResource CardBackground}"
            CornerRadius="16"
            BorderBrush="{DynamicResource BorderColor}"
            BorderThickness="1"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="5" Opacity="0.3"/>
        </Border.Effect>

        <StackPanel Margin="25">
            <!-- Заголовок -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <TextBlock x:Name="IconText" Text="ℹ️" FontSize="28" Margin="0,0,12,0"/>
                <TextBlock x:Name="TitleText" Text="Заголовок" Style="{StaticResource H4Style}" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Сообщение -->
            <TextBlock x:Name="MessageText" 
                       Text="Сообщение"
                       Style="{StaticResource BodyTextStyle}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,20"/>

            <!-- Кнопки -->
            <StackPanel x:Name="ButtonsPanel" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="OkButton" 
                        Content="OK" 
                        Style="{StaticResource PrimaryButton}"
                        Width="90"
                        Margin="0,0,10,0"/>
                <Button x:Name="YesButton" 
                        Content="Да" 
                        Style="{StaticResource PrimaryButton}"
                        Width="90"
                        Margin="0,0,10,0"
                        Visibility="Collapsed"/>
                <Button x:Name="NoButton" 
                        Content="Нет" 
                        Style="{StaticResource SecondaryButton}"
                        Width="90"
                        Margin="0,0,0,0"
                        Visibility="Collapsed"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
