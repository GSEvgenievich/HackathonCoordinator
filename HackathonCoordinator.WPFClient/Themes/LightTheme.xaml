<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Neo-Soft Light - свежий, чистый, современный -->
    <Color x:Key="PrimaryColor">#0066CC</Color>
    <Color x:Key="PrimaryDarkColor">#0052A3</Color>
    <Color x:Key="SuccessColor">#00A86B</Color>
    <Color x:Key="WarningColor">#FF8C42</Color>
    <Color x:Key="DangerColor">#E5484D</Color>
    <Color x:Key="InfoColor">#3B82F6</Color>
    <Color x:Key="ShadowColor">#1A1A1A</Color>
    <Color x:Key="HoverShadowColor">#000000</Color>

    <SolidColorBrush x:Key="ShadowBrush" Color="{StaticResource ShadowColor}"/>
    <SolidColorBrush x:Key="HoverShadowBrush" Color="{StaticResource HoverShadowColor}"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>

    <!-- Фоны -->
    <ImageSource x:Key="MainBackgroundImage">/Assets/Images/Themes/light_bg.png</ImageSource>
    <ImageSource x:Key="AccentBackgroundImage">/Assets/Images/Themes/light_accent.png</ImageSource>

    <ImageBrush x:Key="MainBackgroundBrush" ImageSource="{StaticResource MainBackgroundImage}" Stretch="UniformToFill"/>
    <ImageBrush x:Key="AccentBackgroundBrush" ImageSource="{StaticResource AccentBackgroundImage}" Stretch="UniformToFill"/>

    <!-- Цвета интерфейса -->
    <SolidColorBrush x:Key="BackgroundColor">#F5F7FA</SolidColorBrush>
    <SolidColorBrush x:Key="CardBackground">#FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="ControlBackground">#F8FAFE</SolidColorBrush>
    <SolidColorBrush x:Key="TextColor">#1A1A2E</SolidColorBrush>
    <SolidColorBrush x:Key="TextSecondaryColor">#64748B</SolidColorBrush>
    <SolidColorBrush x:Key="BorderColor">#E2E8F0</SolidColorBrush>
    <SolidColorBrush x:Key="HoverColor">#F1F5F9</SolidColorBrush>
    <SolidColorBrush x:Key="SidebarBackground">#0066CC</SolidColorBrush>
    <SolidColorBrush x:Key="SidebarTextColor">#FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="SidebarHoverColor">#0052A3</SolidColorBrush>
    <SolidColorBrush x:Key="IconButtonBackground">#0066CC</SolidColorBrush>
    <SolidColorBrush x:Key="IconButtonForeground">#FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="ScrollBarColor">#0066CC</SolidColorBrush>
    <SolidColorBrush x:Key="MyMessageBackground" Color="#0066CC"/>
    <SolidColorBrush x:Key="MyMessageTextColor" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="OtherMessageBackground" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="OtherMessageTextColor" Color="#1A1A2E"/>
    <SolidColorBrush x:Key="MessageTimeColor" Color="#64748B"/>
    <SolidColorBrush x:Key="MyMessageTimeColor" Color="#E2E8F0"/>

</ResourceDictionary>