<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Светлая тема - свежие голубые тона -->
    <Color x:Key="PrimaryColor">#2E86AB</Color>
    <!-- Насыщенный синий -->
    <Color x:Key="PrimaryDarkColor">#1B6B93</Color>
    <Color x:Key="SuccessColor">#27AE60</Color>
    <Color x:Key="WarningColor">#E67E22</Color>
    <Color x:Key="DangerColor">#E74C3C</Color>
    <Color x:Key="InfoColor">#3498DB</Color>
    <Color x:Key="ShadowColor">#20000000</Color>
    <Color x:Key="HoverShadowColor">#40000000</Color>

    <SolidColorBrush x:Key="ShadowBrush" Color="{StaticResource ShadowColor}"/>
    <SolidColorBrush x:Key="HoverShadowBrush" Color="{StaticResource HoverShadowColor}"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>

    <!-- Фоновые изображения -->
    <ImageSource x:Key="MainBackgroundImage">/Assets/Images/Themes/light_bg.png</ImageSource>
    <ImageSource x:Key="AccentBackgroundImage">/Assets/Images/Themes/light_accent.png</ImageSource>

    <ImageBrush x:Key="MainBackgroundBrush" ImageSource="{StaticResource MainBackgroundImage}" Stretch="UniformToFill"/>
    <ImageBrush x:Key="AccentBackgroundBrush" ImageSource="{StaticResource AccentBackgroundImage}" Stretch="UniformToFill"/>

    <!-- Цвета интерфейса для светлой темы -->
    <SolidColorBrush x:Key="BackgroundColor">#F0F9FF</SolidColorBrush>
    <!-- Очень светлый голубой -->
    <SolidColorBrush x:Key="CardBackground">#FFFFFF</SolidColorBrush>
    <!-- Чистый белый для карточек -->
    <SolidColorBrush x:Key="ControlBackground">#F7FBFF</SolidColorBrush>
    <!-- Едва заметный голубой для контролов -->
    <SolidColorBrush x:Key="TextColor">#2C3E50</SolidColorBrush>
    <!-- Темно-синий для текста -->
    <SolidColorBrush x:Key="TextSecondaryColor">#5D6D7E</SolidColorBrush>
    <!-- Серо-синий для второстепенного -->
    <SolidColorBrush x:Key="BorderColor">#D6EAF8</SolidColorBrush>
    <!-- Светло-голубые границы -->
    <SolidColorBrush x:Key="HoverColor">#EBF5FB</SolidColorBrush>
    <!-- Легкая голубая подсветка -->
    <SolidColorBrush x:Key="SidebarBackground">#61B3E1</SolidColorBrush>
    <!-- Используем light_accent -->
    <SolidColorBrush x:Key="SidebarTextColor">#FFFFFF</SolidColorBrush>
    <!-- Белый текст на цветном фоне -->
    <SolidColorBrush x:Key="SidebarHoverColor">#51A3D1</SolidColorBrush>
    <!-- Чуть темнее accent -->
    <SolidColorBrush x:Key="IconButtonBackground">#2E86AB</SolidColorBrush>
    <SolidColorBrush x:Key="IconButtonForeground">#FFFFFF</SolidColorBrush>

</ResourceDictionary>