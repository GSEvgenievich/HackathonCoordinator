<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Neo-Soft Summer - сочный, освежающий -->
    <Color x:Key="PrimaryColor">#059669</Color>
    <Color x:Key="PrimaryDarkColor">#047857</Color>
    <Color x:Key="SuccessColor">#22C55E</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="DangerColor">#EF4444</Color>
    <Color x:Key="InfoColor">#3B82F6</Color>
    <Color x:Key="ShadowColor">#1A4A2A</Color>
    <Color x:Key="HoverShadowColor">#40000000</Color>

    <SolidColorBrush x:Key="ShadowBrush" Color="{StaticResource ShadowColor}"/>
    <SolidColorBrush x:Key="HoverShadowBrush" Color="{StaticResource HoverShadowColor}"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>

    <!-- Фоны -->
    <ImageSource x:Key="MainBackgroundImage">/Assets/Images/Themes/summer_bg.png</ImageSource>
    <ImageSource x:Key="AccentBackgroundImage">/Assets/Images/Themes/summer_accent.png</ImageSource>

    <ImageBrush x:Key="MainBackgroundBrush" ImageSource="{StaticResource MainBackgroundImage}" Stretch="UniformToFill"/>
    <ImageBrush x:Key="AccentBackgroundBrush" ImageSource="{StaticResource AccentBackgroundImage}" Stretch="UniformToFill"/>

    <!-- Цвета интерфейса -->
    <SolidColorBrush x:Key="BackgroundColor">#ECFDF5</SolidColorBrush>
    <SolidColorBrush x:Key="CardBackground">#FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="ControlBackground">#F0FDF4</SolidColorBrush>
    <SolidColorBrush x:Key="TextColor">#064E3B</SolidColorBrush>
    <SolidColorBrush x:Key="TextSecondaryColor">#065F46</SolidColorBrush>
    <SolidColorBrush x:Key="BorderColor">#D1FAE5</SolidColorBrush>
    <SolidColorBrush x:Key="HoverColor">#E6F9F0</SolidColorBrush>
    <SolidColorBrush x:Key="SidebarBackground">#059669</SolidColorBrush>
    <SolidColorBrush x:Key="SidebarTextColor">#FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="SidebarHoverColor">#047857</SolidColorBrush>
    <SolidColorBrush x:Key="IconButtonBackground">#059669</SolidColorBrush>
    <SolidColorBrush x:Key="IconButtonForeground">#FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="ScrollBarColor">#059669</SolidColorBrush>
    <SolidColorBrush x:Key="MyMessageBackground" Color="#059669"/>
    <SolidColorBrush x:Key="MyMessageTextColor" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="OtherMessageBackground" Color="#D1FAE5"/>
    <SolidColorBrush x:Key="OtherMessageTextColor" Color="#064E3B"/>
    <SolidColorBrush x:Key="MessageTimeColor" Color="#065F46"/>
    <SolidColorBrush x:Key="MyMessageTimeColor" Color="#A7F3D0"/>

</ResourceDictionary>