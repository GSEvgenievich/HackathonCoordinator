<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Летние цвета - гармония с зелеными фонами -->
    <Color x:Key="PrimaryColor">#6A8457</Color>
    <!-- Используем accent цвет -->
    <Color x:Key="PrimaryDarkColor">#5A7447</Color>
    <Color x:Key="SuccessColor">#4CAF50</Color>
    <Color x:Key="WarningColor">#FF9800</Color>
    <Color x:Key="DangerColor">#F44336</Color>
    <Color x:Key="InfoColor">#2196F3</Color>
    <Color x:Key="ShadowColor">#20000000</Color>
    <Color x:Key="HoverShadowColor">#40000000</Color>

    <SolidColorBrush x:Key="ShadowBrush" Color="{StaticResource ShadowColor}"/>
    <SolidColorBrush x:Key="HoverShadowBrush" Color="{StaticResource HoverShadowColor}"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>

    <!-- Фоны -->
    <ImageSource x:Key="MainBackgroundImage">/Assets/Images/Themes/summer_bg.png</ImageSource>
    <ImageSource x:Key="AccentBackgroundImage">/Assets/Images/Themes/summer_accent.png</ImageSource>

    <ImageBrush x:Key="MainBackgroundBrush" ImageSource="{StaticResource MainBackgroundImage}" Stretch="UniformToFill"/>
    <ImageBrush x:Key="AccentBackgroundBrush" ImageSource="{StaticResource AccentBackgroundImage}" Stretch="UniformToFill"/>

    <!-- Цвета интерфейса -->
    <SolidColorBrush x:Key="BackgroundColor">#F1F8E9</SolidColorBrush>
    <SolidColorBrush x:Key="CardBackground">#FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="ControlBackground">#F9FDF7</SolidColorBrush>
    <SolidColorBrush x:Key="TextColor">#2E4C2E</SolidColorBrush>
    <!-- Темно-зеленый для контраста -->
    <SolidColorBrush x:Key="TextSecondaryColor">#556E55</SolidColorBrush>
    <SolidColorBrush x:Key="BorderColor">#DCEBD4</SolidColorBrush>
    <SolidColorBrush x:Key="HoverColor">#EDF7E7</SolidColorBrush>
    <SolidColorBrush x:Key="SidebarBackground">#6A8457</SolidColorBrush>
    <SolidColorBrush x:Key="SidebarTextColor">#FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="SidebarHoverColor">#5A7447</SolidColorBrush>
    <SolidColorBrush x:Key="IconButtonBackground">#6A8457</SolidColorBrush>
    <SolidColorBrush x:Key="IconButtonForeground">#FFFFFF</SolidColorBrush>

</ResourceDictionary>