<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Осенние цвета - гармония с теплыми бежево-оранжевыми фонами -->
    <Color x:Key="PrimaryColor">#EEB975</Color>
    <!-- Используем accent цвет -->
    <Color x:Key="PrimaryDarkColor">#DEA965</Color>
    <Color x:Key="SuccessColor">#8BC34A</Color>
    <Color x:Key="WarningColor">#FFA726</Color>
    <Color x:Key="DangerColor">#E74C3C</Color>
    <Color x:Key="InfoColor">#4DB6AC</Color>
    <Color x:Key="ShadowColor">#20000000</Color>
    <Color x:Key="HoverShadowColor">#40000000</Color>

    <SolidColorBrush x:Key="ShadowBrush" Color="{StaticResource ShadowColor}"/>
    <SolidColorBrush x:Key="HoverShadowBrush" Color="{StaticResource HoverShadowColor}"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>

    <!-- Фоны -->
    <ImageSource x:Key="MainBackgroundImage">/Assets/Images/Themes/autumn_bg.png</ImageSource>
    <ImageSource x:Key="AccentBackgroundImage">/Assets/Images/Themes/autumn_accent.png</ImageSource>

    <ImageBrush x:Key="MainBackgroundBrush" ImageSource="{StaticResource MainBackgroundImage}" Stretch="UniformToFill"/>
    <ImageBrush x:Key="AccentBackgroundBrush" ImageSource="{StaticResource AccentBackgroundImage}" Stretch="UniformToFill"/>

    <!-- Цвета интерфейса -->
    <SolidColorBrush x:Key="BackgroundColor">#FAF6F0</SolidColorBrush>
    <SolidColorBrush x:Key="CardBackground">#FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="ControlBackground">#FDFAF5</SolidColorBrush>
    <SolidColorBrush x:Key="TextColor">#5D4037</SolidColorBrush>
    <SolidColorBrush x:Key="ScrollBarColor">#EEB975</SolidColorBrush>
    <!-- Теплый коричневый -->
    <SolidColorBrush x:Key="TextSecondaryColor">#795548</SolidColorBrush>
    <SolidColorBrush x:Key="BorderColor">#E8DBCE</SolidColorBrush>
    <SolidColorBrush x:Key="HoverColor">#F5EFE6</SolidColorBrush>
    <SolidColorBrush x:Key="SidebarBackground">#EEB975</SolidColorBrush>
    <SolidColorBrush x:Key="SidebarTextColor">#5D4037</SolidColorBrush>
    <!-- Темный текст для контраста -->
    <SolidColorBrush x:Key="SidebarHoverColor">#E6AF65</SolidColorBrush>
    <SolidColorBrush x:Key="IconButtonBackground">#EEB975</SolidColorBrush>
    <SolidColorBrush x:Key="IconButtonForeground">#5D4037</SolidColorBrush>

</ResourceDictionary>