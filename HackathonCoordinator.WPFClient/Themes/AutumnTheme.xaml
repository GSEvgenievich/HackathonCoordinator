<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Neo-Soft Autumn - теплый, уютный -->
    <Color x:Key="PrimaryColor">#E67E22</Color>
    <Color x:Key="PrimaryDarkColor">#D35400</Color>
    <Color x:Key="SuccessColor">#27AE60</Color>
    <Color x:Key="WarningColor">#F39C12</Color>
    <Color x:Key="DangerColor">#E74C3C</Color>
    <Color x:Key="InfoColor">#3498DB</Color>
    <Color x:Key="ShadowColor">#4A2A0A</Color>
    <Color x:Key="HoverShadowColor">#40000000</Color>

    <SolidColorBrush x:Key="ShadowBrush" Color="{StaticResource ShadowColor}"/>
    <SolidColorBrush x:Key="HoverShadowBrush" Color="{StaticResource HoverShadowColor}"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>

    <!-- Фоны -->
    <ImageSource x:Key="MainBackgroundImage">/Assets/Images/Themes/autumn_bg.png</ImageSource>
    <ImageSource x:Key="AccentBackgroundImage">/Assets/Images/Themes/autumn_accent.png</ImageSource>

    <ImageBrush x:Key="MainBackgroundBrush" ImageSource="{StaticResource MainBackgroundImage}" Stretch="UniformToFill"/>
    <ImageBrush x:Key="AccentBackgroundBrush" ImageSource="{StaticResource AccentBackgroundImage}" Stretch="UniformToFill"/>

    <!-- Цвета интерфейса -->
    <SolidColorBrush x:Key="BackgroundColor">#FEF5E7</SolidColorBrush>
    <SolidColorBrush x:Key="CardBackground">#FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="ControlBackground">#FFF8F0</SolidColorBrush>
    <SolidColorBrush x:Key="TextColor">#5D3A1A</SolidColorBrush>
    <SolidColorBrush x:Key="TextSecondaryColor">#8B6914</SolidColorBrush>
    <SolidColorBrush x:Key="BorderColor">#F5E6D3</SolidColorBrush>
    <SolidColorBrush x:Key="HoverColor">#FDF3E7</SolidColorBrush>
    <SolidColorBrush x:Key="SidebarBackground">#E67E22</SolidColorBrush>
    <SolidColorBrush x:Key="SidebarTextColor">#FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="SidebarHoverColor">#D35400</SolidColorBrush>
    <SolidColorBrush x:Key="IconButtonBackground">#E67E22</SolidColorBrush>
    <SolidColorBrush x:Key="IconButtonForeground">#FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="ScrollBarColor">#E67E22</SolidColorBrush>
    <SolidColorBrush x:Key="MyMessageBackground" Color="#E67E22"/>
    <SolidColorBrush x:Key="MyMessageTextColor" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="OtherMessageBackground" Color="#FEF3E2"/>
    <SolidColorBrush x:Key="OtherMessageTextColor" Color="#5D3A1A"/>
    <SolidColorBrush x:Key="MessageTimeColor" Color="#8B6914"/>
    <SolidColorBrush x:Key="MyMessageTimeColor" Color="#FDE8D0"/>

</ResourceDictionary>