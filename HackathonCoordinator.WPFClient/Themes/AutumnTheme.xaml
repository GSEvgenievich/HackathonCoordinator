<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Осенние цвета -->
    <Color x:Key="PrimaryColor">#FFD35400</Color>
    <!-- Теплый оранжевый -->
    <Color x:Key="PrimaryDarkColor">#FFBA4A00</Color>
    <Color x:Key="SuccessColor">#FF27AE60</Color>
    <Color x:Key="WarningColor">#FFE67E22</Color>
    <Color x:Key="DangerColor">#FFE74C3C</Color>
    <Color x:Key="InfoColor">#FF8D6E63</Color>
    <Color x:Key="ShadowColor">#40000000</Color>
    <Color x:Key="HoverShadowColor">#60000000</Color>

    <SolidColorBrush x:Key="ShadowBrush" Color="{StaticResource ShadowColor}"/>
    <SolidColorBrush x:Key="HoverShadowBrush" Color="{StaticResource HoverShadowColor}"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>

    <!-- Фоновые изображения для осени -->
    <ImageSource x:Key="MainBackgroundImage">/Assets/Images/Themes/autumn_bg.png</ImageSource>
    <ImageSource x:Key="AccentBackgroundImage">/Assets/Images/Themes/autumn_accent.png</ImageSource>

    <!-- Фоны -->
    <ImageBrush x:Key="MainBackgroundBrush" ImageSource="{StaticResource MainBackgroundImage}" Stretch="UniformToFill"/>
    <ImageBrush x:Key="AccentBackgroundBrush" ImageSource="{StaticResource AccentBackgroundImage}" Stretch="UniformToFill"/>

    <!-- Цвета интерфейса для осени -->
    <SolidColorBrush x:Key="BackgroundColor">#FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="CardBackground">#FFF8F0</SolidColorBrush>
    <SolidColorBrush x:Key="ControlBackground">#FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="TextColor">#2C3E50</SolidColorBrush>
    <SolidColorBrush x:Key="TextSecondaryColor">#7F8C8D</SolidColorBrush>
    <SolidColorBrush x:Key="BorderColor">#FFE8D0</SolidColorBrush>
    <SolidColorBrush x:Key="HoverColor">#FFF0E0</SolidColorBrush>
    <SolidColorBrush x:Key="SidebarBackground">#80D35400</SolidColorBrush>
    <SolidColorBrush x:Key="SidebarTextColor">#FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="SidebarHoverColor">#A0D35400</SolidColorBrush>
    <SolidColorBrush x:Key="IconButtonBackground">#FFD35400</SolidColorBrush>
    <SolidColorBrush x:Key="IconButtonForeground">#FFFFFF</SolidColorBrush>

</ResourceDictionary>