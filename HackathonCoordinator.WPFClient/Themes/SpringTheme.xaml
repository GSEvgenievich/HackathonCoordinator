<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Neo-Soft Spring - нежный, свежий -->
    <Color x:Key="PrimaryColor">#DB2777</Color>
    <Color x:Key="PrimaryDarkColor">#BE185D</Color>
    <Color x:Key="SuccessColor">#22C55E</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="DangerColor">#EF4444</Color>
    <Color x:Key="InfoColor">#0EA5E9</Color>
    <Color x:Key="ShadowColor">#4A0A2A</Color>
    <Color x:Key="HoverShadowColor">#40000000</Color>

    <SolidColorBrush x:Key="ShadowBrush" Color="{StaticResource ShadowColor}"/>
    <SolidColorBrush x:Key="HoverShadowBrush" Color="{StaticResource HoverShadowColor}"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>

    <!-- Фоны -->
    <ImageSource x:Key="MainBackgroundImage">/Assets/Images/Themes/spring_bg.png</ImageSource>
    <ImageSource x:Key="AccentBackgroundImage">/Assets/Images/Themes/spring_accent.png</ImageSource>

    <ImageBrush x:Key="MainBackgroundBrush" ImageSource="{StaticResource MainBackgroundImage}" Stretch="UniformToFill"/>
    <ImageBrush x:Key="AccentBackgroundBrush" ImageSource="{StaticResource AccentBackgroundImage}" Stretch="UniformToFill"/>

    <!-- Цвета интерфейса -->
    <SolidColorBrush x:Key="BackgroundColor">#FFF5F6</SolidColorBrush>
    <SolidColorBrush x:Key="CardBackground">#FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="ControlBackground">#FFF1F3</SolidColorBrush>
    <SolidColorBrush x:Key="TextColor">#831843</SolidColorBrush>
    <SolidColorBrush x:Key="TextSecondaryColor">#9D174D</SolidColorBrush>
    <SolidColorBrush x:Key="BorderColor">#FCE7F3</SolidColorBrush>
    <SolidColorBrush x:Key="HoverColor">#FDF2F8</SolidColorBrush>
    <SolidColorBrush x:Key="SidebarBackground">#DB2777</SolidColorBrush>
    <SolidColorBrush x:Key="SidebarTextColor">#FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="SidebarHoverColor">#BE185D</SolidColorBrush>
    <SolidColorBrush x:Key="IconButtonBackground">#DB2777</SolidColorBrush>
    <SolidColorBrush x:Key="IconButtonForeground">#FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="ScrollBarColor">#DB2777</SolidColorBrush>
    <SolidColorBrush x:Key="MyMessageBackground" Color="#DB2777"/>
    <SolidColorBrush x:Key="MyMessageTextColor" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="OtherMessageBackground" Color="#FCE7F3"/>
    <SolidColorBrush x:Key="OtherMessageTextColor" Color="#831843"/>
    <SolidColorBrush x:Key="MessageTimeColor" Color="#9D174D"/>
    <SolidColorBrush x:Key="MyMessageTimeColor" Color="#FBCFE8"/>

</ResourceDictionary>