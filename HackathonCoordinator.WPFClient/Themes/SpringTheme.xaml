<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Весенние цвета - гармония с розово-бежевыми фонами -->
    <Color x:Key="PrimaryColor">#D4A5A5</Color>
    <!-- Теплый розовый -->
    <Color x:Key="PrimaryDarkColor">#C49595</Color>
    <Color x:Key="SuccessColor">#88C9A1</Color>
    <!-- Мягкий зеленый -->
    <Color x:Key="WarningColor">#E6B87E</Color>
    <Color x:Key="DangerColor">#E69595</Color>
    <Color x:Key="InfoColor">#9BCFCF</Color>
    <!-- Мягкий бирюзовый -->
    <Color x:Key="ShadowColor">#20000000</Color>
    <Color x:Key="HoverShadowColor">#40000000</Color>

    <SolidColorBrush x:Key="ShadowBrush" Color="{StaticResource ShadowColor}"/>
    <SolidColorBrush x:Key="HoverShadowBrush" Color="{StaticResource HoverShadowColor}"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>

    <!-- Фоны -->
    <ImageSource x:Key="MainBackgroundImage">/Assets/Images/Themes/spring_bg.png</ImageSource>
    <ImageSource x:Key="AccentBackgroundImage">/Assets/Images/Themes/spring_accent.png</ImageSource>

    <ImageBrush x:Key="MainBackgroundBrush" ImageSource="{StaticResource MainBackgroundImage}" Stretch="UniformToFill"/>
    <ImageBrush x:Key="AccentBackgroundBrush" ImageSource="{StaticResource AccentBackgroundImage}" Stretch="UniformToFill"/>

    <!-- Цвета интерфейса - обеспечивают контраст на фоне изображений -->
    <SolidColorBrush x:Key="BackgroundColor">#FFF8F6</SolidColorBrush>
    <SolidColorBrush x:Key="CardBackground">#FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="ControlBackground">#FDFAFA</SolidColorBrush>
    <SolidColorBrush x:Key="TextColor">#5D4037</SolidColorBrush>
    <!-- Теплый коричневый для читаемости -->
    <SolidColorBrush x:Key="TextSecondaryColor">#8D6E63</SolidColorBrush>
    <SolidColorBrush x:Key="BorderColor">#E8D6D3</SolidColorBrush>
    <SolidColorBrush x:Key="HoverColor">#F5EDED</SolidColorBrush>
    <SolidColorBrush x:Key="SidebarBackground">#DE9F9A</SolidColorBrush>
    <!-- Используем accent цвет -->
    <SolidColorBrush x:Key="SidebarTextColor">#FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="SidebarHoverColor">#D18F8A</SolidColorBrush>
    <SolidColorBrush x:Key="IconButtonBackground">#D4A5A5</SolidColorBrush>
    <SolidColorBrush x:Key="IconButtonForeground">#FFFFFF</SolidColorBrush>

</ResourceDictionary>