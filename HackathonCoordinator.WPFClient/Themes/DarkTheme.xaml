<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Neo-Soft Dark - глубокий, но не давящий -->
    <Color x:Key="PrimaryColor">#3B82F6</Color>
    <Color x:Key="PrimaryDarkColor">#2563EB</Color>
    <Color x:Key="SuccessColor">#10B981</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="DangerColor">#EF4444</Color>
    <Color x:Key="InfoColor">#06B6D4</Color>
    <Color x:Key="ShadowColor">#000000</Color>
    <Color x:Key="HoverShadowColor">#40000000</Color>

    <SolidColorBrush x:Key="ShadowBrush" Color="{StaticResource ShadowColor}"/>
    <SolidColorBrush x:Key="HoverShadowBrush" Color="{StaticResource HoverShadowColor}"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>

    <!-- Фоны -->
    <ImageSource x:Key="MainBackgroundImage">/Assets/Images/Themes/dark_bg.png</ImageSource>
    <ImageSource x:Key="AccentBackgroundImage">/Assets/Images/Themes/dark_accent.png</ImageSource>

    <ImageBrush x:Key="MainBackgroundBrush" ImageSource="{StaticResource MainBackgroundImage}" Stretch="UniformToFill"/>
    <ImageBrush x:Key="AccentBackgroundBrush" ImageSource="{StaticResource AccentBackgroundImage}" Stretch="UniformToFill"/>

    <!-- Цвета интерфейса -->
    <SolidColorBrush x:Key="BackgroundColor">#0F172A</SolidColorBrush>
    <SolidColorBrush x:Key="CardBackground">#1E293B</SolidColorBrush>
    <SolidColorBrush x:Key="ControlBackground">#334155</SolidColorBrush>
    <SolidColorBrush x:Key="TextColor">#F1F5F9</SolidColorBrush>
    <SolidColorBrush x:Key="TextSecondaryColor">#94A3B8</SolidColorBrush>
    <SolidColorBrush x:Key="BorderColor">#334155</SolidColorBrush>
    <SolidColorBrush x:Key="HoverColor">#2D3A4E</SolidColorBrush>
    <SolidColorBrush x:Key="SidebarBackground">#0F172A</SolidColorBrush>
    <SolidColorBrush x:Key="SidebarTextColor">#F1F5F9</SolidColorBrush>
    <SolidColorBrush x:Key="SidebarHoverColor">#1E293B</SolidColorBrush>
    <SolidColorBrush x:Key="IconButtonBackground">#3B82F6</SolidColorBrush>
    <SolidColorBrush x:Key="IconButtonForeground">#FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="ScrollBarColor">#3B82F6</SolidColorBrush>
    <SolidColorBrush x:Key="MyMessageBackground" Color="#3B82F6"/>
    <SolidColorBrush x:Key="MyMessageTextColor" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="OtherMessageBackground" Color="#334155"/>
    <SolidColorBrush x:Key="OtherMessageTextColor" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="MessageTimeColor" Color="#94A3B8"/>
    <SolidColorBrush x:Key="MyMessageTimeColor" Color="#CBD5E1"/>

</ResourceDictionary>