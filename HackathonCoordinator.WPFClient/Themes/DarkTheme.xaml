<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Темная тема - глубокие синие тона -->
    <Color x:Key="PrimaryColor">#5FA8FF</Color>
    <!-- Яркий синий для акцентов -->
    <Color x:Key="PrimaryDarkColor">#4A90E2</Color>
    <Color x:Key="SuccessColor">#2ECC71</Color>
    <Color x:Key="WarningColor">#F39C12</Color>
    <Color x:Key="DangerColor">#E74C3C</Color>
    <Color x:Key="InfoColor">#3498DB</Color>
    <Color x:Key="ShadowColor">#000000</Color>
    <Color x:Key="HoverShadowColor">#40000000</Color>

    <SolidColorBrush x:Key="ShadowBrush" Color="{StaticResource ShadowColor}"/>
    <SolidColorBrush x:Key="HoverShadowBrush" Color="{StaticResource HoverShadowColor}"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>

    <!-- Фоновые изображения -->
    <ImageSource x:Key="MainBackgroundImage">/Assets/Images/Themes/dark_bg.png</ImageSource>
    <ImageSource x:Key="AccentBackgroundImage">/Assets/Images/Themes/dark_accent.png</ImageSource>

    <ImageBrush x:Key="MainBackgroundBrush" ImageSource="{StaticResource MainBackgroundImage}" Stretch="UniformToFill"/>
    <ImageBrush x:Key="AccentBackgroundBrush" ImageSource="{StaticResource AccentBackgroundImage}" Stretch="UniformToFill"/>

    <!-- Цвета интерфейса для темной темы -->
    <SolidColorBrush x:Key="BackgroundColor">#1A1A2E</SolidColorBrush>
    <!-- Темно-синий как у dark_bg -->
    <SolidColorBrush x:Key="CardBackground">#2A2A4E</SolidColorBrush>
    <!-- Чуть светлее фона -->
    <SolidColorBrush x:Key="ControlBackground">#252545</SolidColorBrush>
    <!-- Для инпутов и кнопок -->
    <SolidColorBrush x:Key="TextColor">#FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="ScrollBarColor">#8A2BE2</SolidColorBrush>
    <!-- Белый для максимального контраста -->
    <SolidColorBrush x:Key="TextSecondaryColor">#B8B8D8</SolidColorBrush>
    <!-- Светло-фиолетовый для второстепенного текста -->
    <SolidColorBrush x:Key="BorderColor">#404070</SolidColorBrush>
    <!-- Синеватые границы -->
    <SolidColorBrush x:Key="HoverColor">#353565</SolidColorBrush>
    <!-- Подсветка при наведении -->
    <SolidColorBrush x:Key="SidebarBackground">#040C19</SolidColorBrush>
    <!-- Используем dark_accent -->
    <SolidColorBrush x:Key="SidebarTextColor">#FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="SidebarHoverColor">#0A1429</SolidColorBrush>
    <!-- Чуть светлее accent -->
    <SolidColorBrush x:Key="IconButtonBackground">#5FA8FF</SolidColorBrush>
    <SolidColorBrush x:Key="IconButtonForeground">#FFFFFF</SolidColorBrush>

</ResourceDictionary>