<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:HackathonCoordinator.WPFClient.Converters">

    <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    <converters:BoolToBrushConverter x:Key="BoolToBrushConverter"/>

    <!-- Единая система типографики -->
    <FontFamily x:Key="AppFontFamily">Segoe UI</FontFamily>

    <!-- Базовый стиль для всего текста -->
    <Style x:Key="BaseTextBlock" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
    </Style>

    <!-- Иерархия заголовков -->
    <Style x:Key="H1Style" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlock}">
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="LineHeight" Value="1.2"/>
    </Style>
    
    <Style x:Key="H2Style" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlock}">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="LineHeight" Value="1.3"/>
    </Style>

    <Style x:Key="H3Style" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlock}">
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="LineHeight" Value="1.3"/>
    </Style>

    <Style x:Key="H4Style" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlock}">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="LineHeight" Value="1.4"/>
    </Style>

    <!-- Текстовые стили -->
    <Style x:Key="BodyLargeStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlock}">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="LineHeight" Value="1.5"/>
    </Style>

    <Style x:Key="BodyStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlock}">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="LineHeight" Value="1.5"/>
    </Style>

    <Style x:Key="BodySmallStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlock}">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="LineHeight" Value="1.4"/>
    </Style>

    <Style x:Key="CaptionStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlock}">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="LineHeight" Value="1.3"/>
    </Style>

    <Style x:Key="MicroStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlock}">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="LineHeight" Value="1.2"/>
    </Style>

    <!-- Специализированные текстовые стили -->
    <Style x:Key="BodySecondaryStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyStyle}">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryColor}"/>
    </Style>

    <Style x:Key="CaptionSecondaryStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionStyle}">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryColor}"/>
    </Style>

    <Style x:Key="MicroSecondaryStyle" TargetType="TextBlock" BasedOn="{StaticResource MicroStyle}">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryColor}"/>
    </Style>

    <!-- Стили для специальных случаев (обратная совместимость) -->
    <Style x:Key="PageTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource H2Style}">
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,0,20"/>
    </Style>

    <Style x:Key="BodyTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BodySecondaryStyle}"/>

    <!-- Стили контролов -->
    <Style TargetType="TextBox" x:Key="ModernTextBox">
        <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border" 
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost" 
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            <TextBlock x:Name="placeholderText"
                                       Text="{TemplateBinding Tag}"
                                       Style="{StaticResource BodySecondaryStyle}"
                                       Margin="{TemplateBinding Padding}"
                                       VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                       Visibility="Collapsed"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Text" Value="">
                            <Setter TargetName="placeholderText" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            <Setter TargetName="placeholderText" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TextBox" x:Key="ReadingTextBox">
        <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="Focusable" Value="True"/>
        <Setter Property="Cursor" Value="IBeam"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border" 
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost" 
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="PasswordBox" x:Key="ModernPasswordBox">
        <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="Cursor" Value="IBeam"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border x:Name="border" 
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            SnapsToDevicePixels="True">
                        <Grid Margin="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            <TextBlock x:Name="placeholderText"
                                       Text="{TemplateBinding Tag}"
                                       Style="{StaticResource BodySecondaryStyle}"
                                       VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                       Visibility="Visible"
                                       IsHitTestVisible="False"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            <Setter TargetName="placeholderText" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <DataTrigger Binding="{Binding Password, RelativeSource={RelativeSource Self}}" Value="">
                            <Setter TargetName="placeholderText" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Password, RelativeSource={RelativeSource Self}}">
                            <Setter TargetName="placeholderText" Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Кнопки -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" 
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryDarkBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryDarkBrush}"/>
                            <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" 
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="RoundIconButton" TargetType="Button">
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="Background" Value="{DynamicResource IconButtonBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource IconButtonForeground}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="16">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Стиль для боковой панели -->
    <Style x:Key="SidebarButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource SidebarTextColor}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Height" Value="50"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" 
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Left" 
                                          VerticalAlignment="Center"
                                          Margin="10,0,0,0"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource SidebarHoverColor}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                            <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ModalDangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>
    
    <!-- Карточки -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="15" 
                                  ShadowDepth="3" 
                                  Opacity="0.15"
                                  Color="{DynamicResource ShadowColor}"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="InteractiveCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="20" 
                                          ShadowDepth="8" 
                                          Opacity="0.4"
                                          Color="{DynamicResource HoverShadowColor}"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="Background" Value="{DynamicResource HoverColor}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                <Setter Property="BorderThickness" Value="2"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Комбо-бокс -->
    <Style x:Key="ModernComboBox" TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource BackgroundColor}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Border.CornerRadius" Value="8"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                <Setter Property="Background" Value="{DynamicResource HoverColor}"/>
            </Trigger>
            <Trigger Property="IsDropDownOpen" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- DatePicker -->
    <Style x:Key="ModernDatePicker" TargetType="DatePicker">
        <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
            </Trigger>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                <Setter Property="BorderThickness" Value="2"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DatePickerTextBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- Специализированные стили для TeamPage -->
    <Style x:Key="NavigationButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
        <Setter Property="MinWidth" Value="100"/>
        <Setter Property="Padding" Value="12,8"/>
    </Style>

    <Style x:Key="PageHeaderStyle" TargetType="TextBlock" BasedOn="{StaticResource H1Style}"/>
    <Style x:Key="PageSubtitleStyle" TargetType="TextBlock" BasedOn="{StaticResource BodySecondaryStyle}">
        <Setter Property="Margin" Value="0,5,0,0"/>
    </Style>
    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock" BasedOn="{StaticResource H3Style}"/>
    <Style x:Key="SectionTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource H4Style}"/>

    <!-- Статистика -->
    <Style x:Key="StatsContainerStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="StatsHeaderStyle" TargetType="TextBlock" BasedOn="{StaticResource MicroSecondaryStyle}">
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <Style x:Key="StatsLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource BodySecondaryStyle}">
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <Style x:Key="StatsValueStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyStyle}">
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="VerticalDividerStyle" TargetType="Rectangle">
        <Setter Property="Width" Value="1"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="Fill" Value="{DynamicResource BorderColor}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="8,0"/>
    </Style>

    <!-- Действия -->
    <Style x:Key="ActionButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="MinWidth" Value="100"/>
    </Style>

    <!-- Участники -->
    <Style x:Key="MemberCardStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
        <Setter Property="Padding" Value="12"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="AvatarStyle" TargetType="Border">
        <Setter Property="Width" Value="50"/>
        <Setter Property="Height" Value="50"/>
        <Setter Property="CornerRadius" Value="25"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Margin" Value="0,0,15,0"/>
        <Setter Property="Clip">
            <Setter.Value>
                <EllipseGeometry RadiusX="25" RadiusY="25" Center="25,25"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MemberNameStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyLargeStyle}">
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="CurrentUserLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionStyle}">
        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Margin" Value="6,0,0,0"/>
    </Style>

    <Style x:Key="CaptainIconStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyLargeStyle}">
        <Setter Property="Margin" Value="6,0,0,0"/>
    </Style>

    <Style x:Key="MemberRoleStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionSecondaryStyle}">
        <Setter Property="Margin" Value="0,2,0,0"/>
    </Style>

    <!-- Задачи -->
    <Style x:Key="TaskCardStyle" TargetType="Border" BasedOn="{StaticResource InteractiveCardStyle}">
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <Style x:Key="TaskTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyLargeStyle}">
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
    </Style>

    <Style x:Key="TaskDescriptionStyle" TargetType="TextBlock" BasedOn="{StaticResource BodySecondaryStyle}">
        <Setter Property="MaxHeight" Value="40"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>
    
    <!-- Стиль для сообщений -->
    <Style x:Key="MyMessageContainerStyle" TargetType="StackPanel">
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="Margin" Value="0,0,10,0"/>
    </Style>

    <Style x:Key="OtherMessageContainerStyle" TargetType="StackPanel">
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="Margin" Value="0,0,20,0"/>
    </Style>

    <Style x:Key="MyMessageStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="10 5"/>
    </Style>

    <Style x:Key="OtherMessageStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource HoverColor}"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="10 5"/>
    </Style>

    <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryColor}"/>
        <Setter Property="FontWeight" Value="Normal"/>
    </Style>
    
    <!-- Бейджи и мета-информация -->
    <Style x:Key="CounterBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="Margin" Value="10,0,0,0"/>
    </Style>

    <Style x:Key="CounterTextStyle" TargetType="TextBlock" BasedOn="{StaticResource MicroStyle}">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style x:Key="TypeBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="4,2"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
    </Style>

    <Style x:Key="BadgeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource MicroStyle}">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style x:Key="MetaIconStyle" TargetType="TextBlock" BasedOn="{StaticResource MicroStyle}">
        <Setter Property="Margin" Value="8,0,0,0"/>
    </Style>

    <Style x:Key="MetaTextStyle" TargetType="TextBlock" BasedOn="{StaticResource MicroStyle}">
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="2,0,0,0"/>
    </Style>

    <Style x:Key="ExpandArrowStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyStyle}">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryColor}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Иконки -->
    <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource RoundIconButton}"/>
    <Style x:Key="DangerIconButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
        <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
    </Style>

    <!-- Пустые состояния -->
    <Style x:Key="EmptyStateStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="30"/>
        <Setter Property="Margin" Value="0,10,0,0"/>
    </Style>

    <Style x:Key="EmptyStateIconStyle" TargetType="TextBlock" BasedOn="{StaticResource H2Style}">
        <Setter Property="Margin" Value="0,0,12,0"/>
    </Style>

    <Style x:Key="EmptyStateTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyStyle}">
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="EmptyStateSubtitleStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionSecondaryStyle}"/>

    <!-- Модальные окна -->
    <Style x:Key="ModalOverlayStyle" TargetType="Border">
        <Setter Property="Background" Value="#CC000000"/>
        <Setter Property="Panel.ZIndex" Value="1000"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>

    <Style x:Key="ModalDialogStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Width" Value="400"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Padding" Value="25"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="25" 
                                  ShadowDepth="5" 
                                  Opacity="0.3"
                                  Color="{DynamicResource ShadowColor}"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ModalTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource H4Style}">
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="ModalDescriptionStyle" TargetType="TextBlock" BasedOn="{StaticResource BodySecondaryStyle}">
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style x:Key="ModalPrimaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Padding" Value="15,10"/>
        <Setter Property="MinWidth" Value="120"/>
    </Style>

    <Style x:Key="ModalSecondaryButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
        <Setter Property="Padding" Value="15,10"/>
        <Setter Property="MinWidth" Value="80"/>
    </Style>

    <!-- Заголовок секции задач -->
    <Style x:Key="TaskSectionHeaderStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="15"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <!-- Стиль для карточки моей задачи -->
    <Style x:Key="MyTaskCardStyle" TargetType="Border" BasedOn="{StaticResource TaskCardStyle}">
        <Setter Property="BorderBrush" Value="#4CAF50"/>
        <Setter Property="Background" Value="#F8FFF8"/>
    </Style>

    <!-- Стиль для бейджа "ваших задач" -->
    <Style x:Key="MyTasksBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="#E8F5E8"/>
        <Setter Property="BorderBrush" Value="#4CAF50"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="Margin" Value="8,0,0,0"/>
    </Style>

    <Style x:Key="MyTasksCounterTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#2E7D32"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- Стиль для индикатора моей задачи -->
    <Style x:Key="MyTaskIndicatorStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#4CAF50"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Margin" Value="5,0,0,0"/>
    </Style>

    <!-- Стиль для чекбокса -->
    <Style x:Key="ModernCheckBox" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="#CCCCCC"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Check box -->
                        <Border x:Name="checkBoxBorder"
                            Grid.Column="0"
                            Width="16"
                            Height="16"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Margin="0,0,8,0">
                            <Path x:Name="checkMark"
                              Data="M 3 8 L 6 11 L 13 4"
                              Stroke="#FFFFFF"
                              StrokeThickness="2"
                              Stretch="Uniform"
                              Fill="Transparent"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Opacity="0"/>
                        </Border>

                        <!-- Content -->
                        <ContentPresenter Grid.Column="1"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      HorizontalAlignment="Left"/>

                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="checkMark" Property="Opacity" Value="1"/>
                            <Setter TargetName="checkBoxBorder" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                            <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                        </Trigger>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ErrorTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#D32F2F"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="0,5,0,0"/>
    </Style>

    <Style x:Key="ValidTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource ModernTextBox}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsRepoNameValid}" Value="False">
                <Setter Property="BorderBrush" Value="#D32F2F"/>
                <Setter Property="BorderThickness" Value="2"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsRepoNameValid}" Value="True">
                <Setter Property="BorderBrush" Value="#4CAF50"/>
                <Setter Property="BorderThickness" Value="2"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Вертикальный ScrollBar (ваш существующий) -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="{DynamicResource HoverColor}"/>
        <Setter Property="Margin" Value="3 0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Width="10">
                        <Border Background="{TemplateBinding Background}" 
                            CornerRadius="5"/>
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Style>
                                        <Style TargetType="Thumb">
                                            <Setter Property="Background" Value="{DynamicResource ScrollBarColor}"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border CornerRadius="4" 
                                                            Background="{TemplateBinding Background}"
                                                            Margin="1,0"/>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="AliceBlue"/>
                                                </Trigger>
                                                <Trigger Property="IsDragging" Value="True">
                                                    <Setter Property="Background" Value="#222222"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Thumb.Style>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Горизонтальный ScrollBar -->
    <Style x:Key="HorizontalScrollBarStyle" TargetType="ScrollBar">
        <Setter Property="Background" Value="{DynamicResource HoverColor}"/>
        <Setter Property="Margin" Value="0 3"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Height="10">
                        <Border Background="{TemplateBinding Background}" 
                            CornerRadius="5"/>
                        <Track x:Name="PART_Track" IsDirectionReversed="False">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Style>
                                        <Style TargetType="Thumb">
                                            <Setter Property="Background" Value="{DynamicResource ScrollBarColor}"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border CornerRadius="4" 
                                                            Background="{TemplateBinding Background}"
                                                            Margin="0,1"/>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="AliceBlue"/>
                                                </Trigger>
                                                <Trigger Property="IsDragging" Value="True">
                                                    <Setter Property="Background" Value="#222222"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Thumb.Style>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>