<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Neo-Soft Winter - свежий, ледяной -->
    <Color x:Key="PrimaryColor">#0891B2</Color>
    <Color x:Key="PrimaryDarkColor">#0E7490</Color>
    <Color x:Key="SuccessColor">#10B981</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="DangerColor">#EF4444</Color>
    <Color x:Key="InfoColor">#3B82F6</Color>
    <Color x:Key="ShadowColor">#1A3A4A</Color>
    <Color x:Key="HoverShadowColor">#40000000</Color>

    <SolidColorBrush x:Key="ShadowBrush" Color="{StaticResource ShadowColor}"/>
    <SolidColorBrush x:Key="HoverShadowBrush" Color="{StaticResource HoverShadowColor}"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>

    <!-- Фоны -->
    <ImageSource x:Key="MainBackgroundImage">/Assets/Images/Themes/winter_bg.png</ImageSource>
    <ImageSource x:Key="AccentBackgroundImage">/Assets/Images/Themes/winter_accent.png</ImageSource>

    <ImageBrush x:Key="MainBackgroundBrush" ImageSource="{StaticResource MainBackgroundImage}" Stretch="UniformToFill"/>
    <ImageBrush x:Key="AccentBackgroundBrush" ImageSource="{StaticResource AccentBackgroundImage}" Stretch="UniformToFill"/>

    <!-- Цвета интерфейса -->
    <SolidColorBrush x:Key="BackgroundColor">#ECFEFF</SolidColorBrush>
    <SolidColorBrush x:Key="CardBackground">#FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="ControlBackground">#F0FDFF</SolidColorBrush>
    <SolidColorBrush x:Key="TextColor">#164E63</SolidColorBrush>
    <SolidColorBrush x:Key="TextSecondaryColor">#155E75</SolidColorBrush>
    <SolidColorBrush x:Key="BorderColor">#CFFAFE</SolidColorBrush>
    <SolidColorBrush x:Key="HoverColor">#E0F2FE</SolidColorBrush>
    <SolidColorBrush x:Key="SidebarBackground">#0891B2</SolidColorBrush>
    <SolidColorBrush x:Key="SidebarTextColor">#FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="SidebarHoverColor">#0E7490</SolidColorBrush>
    <SolidColorBrush x:Key="IconButtonBackground">#0891B2</SolidColorBrush>
    <SolidColorBrush x:Key="IconButtonForeground">#FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="ScrollBarColor">#0891B2</SolidColorBrush>
    <SolidColorBrush x:Key="MyMessageBackground" Color="#0891B2"/>
    <SolidColorBrush x:Key="MyMessageTextColor" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="OtherMessageBackground" Color="#E0F2FE"/>
    <SolidColorBrush x:Key="OtherMessageTextColor" Color="#164E63"/>
    <SolidColorBrush x:Key="MessageTimeColor" Color="#155E75"/>
    <SolidColorBrush x:Key="MyMessageTimeColor" Color="#BAE6FD"/>

</ResourceDictionary>